[
	{
		"id": 0,
		"localized_name": "ミルカ",
		"romanized_name": "Miruca",
		"model_path_hash": "6658023269359396885",
		"text": "――完成した。うん、いい出来。\n思ったより早くできたわ",
		"voice_file": "",
		"still_path_hash": "1034358740077913276",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "ミルカ",
		"romanized_name": "Miruca",
		"model_path_hash": "6658023269359396885",
		"text": "シャル、シャリー、エスカさんとロジーさんも、\n手伝ってくれてありがとう",
		"voice_file": "",
		"still_path_hash": "1034358740077913276",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "エスカ",
		"romanized_name": "Escha",
		"model_path_hash": "4942920317009730088",
		"text": "どういたしまして！\nこちらこそ、頼ってくれてありがとう",
		"voice_file": "",
		"still_path_hash": "8567200502263774699",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "ロジー",
		"romanized_name": "Logy",
		"model_path_hash": "1006275234893630447",
		"text": "また何かあったら、気軽に声をかけてくれ",
		"voice_file": "",
		"still_path_hash": "6585993596609120687",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "ミルカ",
		"romanized_name": "Miruca",
		"model_path_hash": "6658023269359396885",
		"text": "……これ、姉さんに渡してくる",
		"voice_file": "",
		"still_path_hash": "1034358740077913276",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "シャリステラ",
		"romanized_name": "Shallistera",
		"model_path_hash": "90362210238560528",
		"text": "ユリエさん、きっと喜んでくれますね",
		"voice_file": "",
		"still_path_hash": "2239883848991404562",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "シャルロッテ",
		"romanized_name": "Shallotte",
		"model_path_hash": "322297020958821866",
		"text": "うん、絶対だよ！　\nミルカ、行ってらっしゃい",
		"voice_file": "",
		"still_path_hash": "5588667421325366917",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "ミルカ",
		"romanized_name": "Miruca",
		"model_path_hash": "6658023269359396885",
		"text": "ありがとう。行ってくる",
		"voice_file": "",
		"still_path_hash": "1034358740077913276",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "シャルロッテ",
		"romanized_name": "Shallotte",
		"model_path_hash": "322297020958821866",
		"text": "……まったく、素直じゃないなあ",
		"voice_file": "",
		"still_path_hash": "5588667421325366917",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "シャリステラ",
		"romanized_name": "Shallistera",
		"model_path_hash": "90362210238560528",
		"text": "え？",
		"voice_file": "",
		"still_path_hash": "2239883848991404562",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "シャルロッテ",
		"romanized_name": "Shallotte",
		"model_path_hash": "322297020958821866",
		"text": "ミルカのこと。\nほんとは、寂しいはずなのにさ",
		"voice_file": "",
		"still_path_hash": "5588667421325366917",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "シャルロッテ",
		"romanized_name": "Shallotte",
		"model_path_hash": "322297020958821866",
		"text": "ミルカって、ユリエさんと一緒にいるときは\nすこーしだけ柔らかい表情になるんだよね",
		"voice_file": "",
		"still_path_hash": "5588667421325366917",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "シャルロッテ",
		"romanized_name": "Shallotte",
		"model_path_hash": "322297020958821866",
		"text": "本人は気付いてないかもだけど！",
		"voice_file": "",
		"still_path_hash": "5588667421325366917",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "シャリステラ",
		"romanized_name": "Shallistera",
		"model_path_hash": "90362210238560528",
		"text": "……ふふ。うん、そうだね。\nわたしもそう思う",
		"voice_file": "",
		"still_path_hash": "2239883848991404562",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "シャリステラ",
		"romanized_name": "Shallistera",
		"model_path_hash": "90362210238560528",
		"text": "それにきっと、\n寂しいのはミルカさんだけじゃなくて――",
		"voice_file": "",
		"still_path_hash": "2239883848991404562",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 15,
		"localized_name": "ミルカ",
		"romanized_name": "Miruca",
		"model_path_hash": "6658023269359396885",
		"text": "……姉さん、ここにいたのね",
		"voice_file": "",
		"still_path_hash": "1034358740077913276",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 16,
		"localized_name": "ユリエ",
		"romanized_name": "Jurie",
		"model_path_hash": "6932496336129827816",
		"text": "ミルカ、どうしたの？",
		"voice_file": "",
		"still_path_hash": "8415011553540267009",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 17,
		"localized_name": "ミルカ",
		"romanized_name": "Miruca",
		"model_path_hash": "6658023269359396885",
		"text": "……これ、砥石。旅で集めた素材で調合したの。\n……姉さんの旅に役立つと思って",
		"voice_file": "",
		"still_path_hash": "1034358740077913276",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 18,
		"localized_name": "ユリエ",
		"romanized_name": "Jurie",
		"model_path_hash": "6932496336129827816",
		"text": "……ありがとう。\nすごく嬉しい",
		"voice_file": "",
		"still_path_hash": "8415011553540267009",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 19,
		"localized_name": "ミルカ",
		"romanized_name": "Miruca",
		"model_path_hash": "6658023269359396885",
		"text": "姉さんは、よく武器の手入れをしてるから",
		"voice_file": "",
		"still_path_hash": "1034358740077913276",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 20,
		"localized_name": "ユリエ",
		"romanized_name": "Jurie",
		"model_path_hash": "6932496336129827816",
		"text": "ミルカの砥石なら、どんな刃もきっと長持ちするわ",
		"voice_file": "",
		"still_path_hash": "8415011553540267009",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 21,
		"localized_name": "ミルカ",
		"romanized_name": "Miruca",
		"model_path_hash": "6658023269359396885",
		"text": "……姉さんは、きっとこの先の旅でも、\n本を書くのよね",
		"voice_file": "",
		"still_path_hash": "1034358740077913276",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 22,
		"localized_name": "ユリエ",
		"romanized_name": "Jurie",
		"model_path_hash": "6932496336129827816",
		"text": "ええ。色んな場所に行って、色んなものを見て……\nきっと素敵な本にして、ミルカに届ける",
		"voice_file": "",
		"still_path_hash": "8415011553540267009",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 23,
		"localized_name": "ミルカ",
		"romanized_name": "Miruca",
		"model_path_hash": "6658023269359396885",
		"text": "うん、姉さんならできる。たくさん、たくさん、\n姉さんが望むだけ書いてほしい。だから――",
		"voice_file": "",
		"still_path_hash": "1034358740077913276",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 24,
		"localized_name": "ミルカ",
		"romanized_name": "Miruca",
		"model_path_hash": "6658023269359396885",
		"text": "応援してる",
		"voice_file": "",
		"still_path_hash": "1034358740077913276",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 25,
		"localized_name": "ユリエ",
		"romanized_name": "Jurie",
		"model_path_hash": "6932496336129827816",
		"text": "……ミルカの気持ち、ちゃんと伝わった。\nありがとう",
		"voice_file": "",
		"still_path_hash": "8415011553540267009",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 26,
		"localized_name": "ミルカ",
		"romanized_name": "Miruca",
		"model_path_hash": "6658023269359396885",
		"text": "……姉さんが無事に帰ってくるなら、それでいい",
		"voice_file": "",
		"still_path_hash": "1034358740077913276",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 27,
		"localized_name": "ユリエ",
		"romanized_name": "Jurie",
		"model_path_hash": "6932496336129827816",
		"text": "私は必ず帰る。\nミルカの砥石と一緒に、ね",
		"voice_file": "",
		"still_path_hash": "8415011553540267009",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 28,
		"localized_name": "ユリエ",
		"romanized_name": "Jurie",
		"model_path_hash": "6932496336129827816",
		"text": "ミルカ、あなたは私の誇りよ",
		"voice_file": "",
		"still_path_hash": "8415011553540267009",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 29,
		"localized_name": "ミルカ",
		"romanized_name": "Miruca",
		"model_path_hash": "6658023269359396885",
		"text": "姉さん……",
		"voice_file": "",
		"still_path_hash": "1034358740077913276",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 30,
		"localized_name": "ユリエ",
		"romanized_name": "Jurie",
		"model_path_hash": "6932496336129827816",
		"text": "砥石、大切に使うわ",
		"voice_file": "",
		"still_path_hash": "8415011553540267009",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 31,
		"localized_name": "ユリエ",
		"romanized_name": "Jurie",
		"model_path_hash": "6932496336129827816",
		"text": "この先の旅でも、きっと新しい物語を見つけてくる",
		"voice_file": "",
		"still_path_hash": "8415011553540267009",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 32,
		"localized_name": "ユリエ",
		"romanized_name": "Jurie",
		"model_path_hash": "6932496336129827816",
		"text": "ミルカの砥石があれば、\nどんな困難も乗り越えられる気がする",
		"voice_file": "",
		"still_path_hash": "8415011553540267009",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 33,
		"localized_name": "ミルカ",
		"romanized_name": "Miruca",
		"model_path_hash": "6658023269359396885",
		"text": "……姉さん、無理はしないで",
		"voice_file": "",
		"still_path_hash": "1034358740077913276",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 34,
		"localized_name": "ユリエ",
		"romanized_name": "Jurie",
		"model_path_hash": "6932496336129827816",
		"text": "ええ、約束する",
		"voice_file": "",
		"still_path_hash": "8415011553540267009",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 35,
		"localized_name": "エスカ・メーリエ",
		"romanized_name": "Escha Malier",
		"model_path_hash": "0",
		"text": "異邦人の錬金術士。マリオンの仕事を手伝っている。\nアトリエを訪れたところ、ミルカに声をかけられた",
		"voice_file": "",
		"still_path_hash": "8567200502263774699",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 36,
		"localized_name": "ロジックス・フィクサリオ",
		"romanized_name": "Logix Ficsario",
		"model_path_hash": "0",
		"text": "異邦人の錬金術士。通称「ロジー」。\nアトリエを訪れたところ、ミルカに声をかけられた",
		"voice_file": "",
		"still_path_hash": "6585993596609120687",
		"speech_balloon_type_id": 780292254
	}
]