[
	{
		"id": 0,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "7061794453237574237",
		"text": "はあ、はあ……\nリラさん、やっぱり強いね！",
		"voice_file": "",
		"still_path_hash": "7010833269667927555",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "リラ",
		"romanized_name": "Lila",
		"model_path_hash": "6420784340983749558",
		"text": "お前も腕を上げたな。\nここまでやるとは思わなかった",
		"voice_file": "",
		"still_path_hash": "658330190563200680",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "ジェロン",
		"romanized_name": "Geron",
		"model_path_hash": "9151749121035711876",
		"text": "どうやら、残っているのは俺たちだけのようだな",
		"voice_file": "",
		"still_path_hash": "8725176872512870759",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "ティム",
		"romanized_name": "Tim",
		"model_path_hash": "9091556145679123684",
		"text": "兄さん、イザナさん、リラさん、レイニャさん……\nみんなすごいよ",
		"voice_file": "",
		"still_path_hash": "6387934691877097610",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "レイニャ",
		"romanized_name": "Lenja",
		"model_path_hash": "5067796612903841500",
		"text": "レイニャも、ここまで残れるなんて……\n夢みたいです……",
		"voice_file": "",
		"still_path_hash": "326916344881311074",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "7061794453237574237",
		"text": "これで５人……\n誰が勝っても目的は達成できるけど、どうしようか……",
		"voice_file": "",
		"still_path_hash": "7010833269667927555",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "ベスティラ王",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "良い……実に良いぞ！　素晴らしい戦いぶりだ！\n今年の参加者は粒揃いであるな！",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "あ、陛下！　見ていらっしゃったんですね",
		"voice_file": "",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "ベスティラ王",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "血湧き肉躍るこの感覚……久しぶりだ。\nどう収めてくれよう！",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "ベスティラ王",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "……決めたぞ。この興奮は、\n闘いで鎮めるしかあるまい！！！",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "はい？　何を言って――",
		"voice_file": "",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "ベスティラ王",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "はああああ！！！！",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "えええええ！？",
		"voice_file": "",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "ベスティラ王",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "この王自らが相手をしてやろう！　\n余を倒した者こそが、真の勝者だ！！",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "司会",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "な、なんとー！？　王様の飛び入り参加だー！！！",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 15,
		"localized_name": "観客たち",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "わあああああ！！！",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 16,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "くはぁーっ！　なんでもあり、つまり、\nこーいうのもありってことっすか！",
		"voice_file": "",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 17,
		"localized_name": "レイニャ",
		"romanized_name": "Lenja",
		"model_path_hash": "5067796612903841500",
		"text": "観客の皆さん、喜んでるみたいです……",
		"voice_file": "",
		"still_path_hash": "326916344881311074",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 18,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "なんて国だ！",
		"voice_file": "",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 19,
		"localized_name": "リラ",
		"romanized_name": "Lila",
		"model_path_hash": "6420784340983749558",
		"text": "……王自ら飛び入りとはな。\nだが、分かりやすくていい",
		"voice_file": "",
		"still_path_hash": "658330190563200680",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 20,
		"localized_name": "ジェロン",
		"romanized_name": "Geron",
		"model_path_hash": "9151749121035711876",
		"text": "ティムと戦わずに済むなら望むところだ",
		"voice_file": "",
		"still_path_hash": "8725176872512870759",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 21,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "7061794453237574237",
		"text": "よし、元気いっぱい！　絶対に勝つよ！",
		"voice_file": "",
		"still_path_hash": "7010833269667927555",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 22,
		"localized_name": "ティム",
		"romanized_name": "Tim",
		"model_path_hash": "9091556145679123684",
		"text": "はい、みんなで力を合わせて勝ちましょう！",
		"voice_file": "",
		"still_path_hash": "6387934691877097610",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 23,
		"localized_name": "レイニャ",
		"romanized_name": "Lenja",
		"model_path_hash": "5067796612903841500",
		"text": "レイニャも、最後まで諦めません！",
		"voice_file": "",
		"still_path_hash": "326916344881311074",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 24,
		"localized_name": "ベスティラ王",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "かかってこい！\n王の力、見せてやろうぞ！！！",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	}
]