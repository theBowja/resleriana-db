[
	{
		"id": 0,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "いよいよ本番かあ……キンチョーしてきた……",
		"voice_file": "VOICE_MAIN_048_504_01196",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "あんたも緊張とかするのね",
		"voice_file": "VOICE_MAIN_004_504_01197",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "だって、こんな大勢の人の前に出るなんて\n初めてだし……",
		"voice_file": "VOICE_MAIN_048_504_01198",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "そういうときは、観客を別の何かだと思えばよい。\n野菜や果物……そうだ！　ハンマーでもよいぞ",
		"voice_file": "VOICE_MAIN_181_504_01199",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "見渡す限りのハンマー……！\nなんかいける気がしてきた！",
		"voice_file": "VOICE_MAIN_048_504_01200",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "……ま、あんたがいいならいいけど",
		"voice_file": "VOICE_MAIN_004_504_01201",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "609796561237155831",
		"text": "ううう……私たちが用意した舞台装置、\nちゃんと動いてくれますように……",
		"voice_file": "VOICE_MAIN_001_504_01202",
		"still_path_hash": "6580594669171159823",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "あはは、レスナちゃんが一番緊張してるかも",
		"voice_file": "VOICE_MAIN_048_504_01203",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "ララ",
		"romanized_name": "Lara",
		"model_path_hash": "4015600840793749786",
		"text": "そう思う気持ちも分かりますが……\n「お祭り」なのですから、楽しまなくては損ですわよ",
		"voice_file": "VOICE_MAIN_005_504_01204",
		"still_path_hash": "803162819272915998",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "スタッフ",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "『Ｃｕｔｉｅ☆ＡｎｉｍａＬ』さん、\nスタンバイお願いします！",
		"voice_file": "VOICE_MAIN_715_504_01205",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "はい！",
		"voice_file": "VOICE_MAIN_181_504_01206",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "見てて、レスナちゃん。緊張が吹き飛んじゃうくらい\n楽しいライブにするから！",
		"voice_file": "VOICE_MAIN_048_504_01207",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "期待には必ず応えてみせるわ。私にとって、\nこれが世界一のアイドルへの第一歩になるんだから",
		"voice_file": "VOICE_MAIN_004_504_01208",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "見る者すべてが「あっ」と驚くような、\n最高のステージを作り上げてみせまする！",
		"voice_file": "VOICE_MAIN_181_504_01209",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "609796561237155831",
		"text": "頑張ってね、みんな！",
		"voice_file": "VOICE_MAIN_001_504_01210",
		"still_path_hash": "6580594669171159823",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 15,
		"localized_name": "ララ",
		"romanized_name": "Lara",
		"model_path_hash": "4015600840793749786",
		"text": "あなたたちの歌と踊りで、\n観客を沸かせてみせなさい！",
		"voice_file": "VOICE_MAIN_005_504_01211",
		"still_path_hash": "803162819272915998",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 16,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "では、参ろうか！　一世一代の大勝負に！",
		"voice_file": "VOICE_MAIN_181_504_01212",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 17,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "いつも通りやるだけよ。\nだって、私はいつも完璧なんだから",
		"voice_file": "VOICE_MAIN_004_504_01213",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 18,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "目いっぱい盛り上げていこー！　おー！",
		"voice_file": "VOICE_MAIN_048_504_01214",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 19,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "コンコン！　貴殿の心にお邪魔しまする！",
		"voice_file": "VOICE_MAIN_181_504_01215",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 20,
		"localized_name": "オタク兄",
		"romanized_name": "Geron",
		"model_path_hash": "9151749121035711876",
		"text": "いらっしゃーい！",
		"voice_file": "VOICE_MAIN_003_504_01216",
		"still_path_hash": "8725176872512870759",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 21,
		"localized_name": "オタク弟",
		"romanized_name": "Tim",
		"model_path_hash": "9091556145679123684",
		"text": "いらっしゃーい！",
		"voice_file": "VOICE_MAIN_604_504_01217",
		"still_path_hash": "6387934691877097610",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 22,
		"localized_name": "観客たち",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "いらっしゃーい！",
		"voice_file": "VOICE_MAIN_716_504_01218",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 23,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "キツネの鬼門でございます！",
		"voice_file": "VOICE_MAIN_181_504_01219",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 24,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "絶対一番、ナンバーワン！　ハムスターのヨハナよ",
		"voice_file": "VOICE_MAIN_004_504_01220",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 25,
		"localized_name": "オタク兄",
		"romanized_name": "Geron",
		"model_path_hash": "9151749121035711876",
		"text": "よっ！　一番星！",
		"voice_file": "VOICE_MAIN_003_504_01221",
		"still_path_hash": "8725176872512870759",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 26,
		"localized_name": "オタク弟",
		"romanized_name": "Tim",
		"model_path_hash": "9091556145679123684",
		"text": "よっ！　一番星！",
		"voice_file": "VOICE_MAIN_604_504_01222",
		"still_path_hash": "6387934691877097610",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 27,
		"localized_name": "観客たち",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "よっ！　一番星！",
		"voice_file": "VOICE_MAIN_716_504_01223",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 28,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "ネズミじゃないから、覚えておいて",
		"voice_file": "VOICE_MAIN_004_504_01224",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 29,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "ねこじゃらしよりハンマー！",
		"voice_file": "VOICE_MAIN_048_504_01225",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 30,
		"localized_name": "オタク兄",
		"romanized_name": "Geron",
		"model_path_hash": "9151749121035711876",
		"text": "ハンマー！",
		"voice_file": "VOICE_MAIN_003_504_01226",
		"still_path_hash": "8725176872512870759",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 31,
		"localized_name": "オタク弟",
		"romanized_name": "Tim",
		"model_path_hash": "9091556145679123684",
		"text": "ハンマー！",
		"voice_file": "VOICE_MAIN_604_504_01227",
		"still_path_hash": "6387934691877097610",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 32,
		"localized_name": "観客たち",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "ハンマー！",
		"voice_file": "VOICE_MAIN_716_504_01228",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 33,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "イザナだよ！　よろしくね！",
		"voice_file": "VOICE_MAIN_048_504_01229",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 34,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "アタシたち――",
		"voice_file": "VOICE_MAIN_048_504_01230",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 35,
		"localized_name": "三人",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "『Ｃｕｔｉｅ☆ＡｎｉｍａＬ』です！",
		"voice_file": "VOICE_MAIN_181_504_01231",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 36,
		"localized_name": "",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "『Ｃｕｔｉｅ☆ＡｎｉｍａＬ』です！",
		"voice_file": "VOICE_MAIN_004_504_01232",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 37,
		"localized_name": "",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "『Ｃｕｔｉｅ☆ＡｎｉｍａＬ』です！",
		"voice_file": "VOICE_MAIN_048_504_01233",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 38,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "年の瀬の祭典、大いに盛り上がっていきましょう！",
		"voice_file": "VOICE_MAIN_181_504_01234",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 39,
		"localized_name": "ジェロン",
		"romanized_name": "Geron",
		"model_path_hash": "7036248754503774915",
		"text": "おおおおおおっ！！",
		"voice_file": "VOICE_MAIN_003_504_01235",
		"still_path_hash": "6398968499954469286",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 40,
		"localized_name": "ティム",
		"romanized_name": "Tim",
		"model_path_hash": "9091556145679123684",
		"text": "おおおおおおっ！！",
		"voice_file": "VOICE_MAIN_604_504_01236",
		"still_path_hash": "6387934691877097610",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 41,
		"localized_name": "観客たち",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "おおおおおおっ！！",
		"voice_file": "VOICE_MAIN_716_504_01237",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 42,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "聞いてください――",
		"voice_file": "VOICE_MAIN_004_504_01238",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 43,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "「わんだふるらいふ！」",
		"voice_file": "VOICE_MAIN_048_504_01239",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	}
]