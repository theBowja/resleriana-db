[
	{
		"id": 0,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "ふんふふふ～ん",
		"voice_file": "VOICE_MAIN_001_037_00791",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "あ……",
		"voice_file": "VOICE_MAIN_002_037_00792",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "リアス",
		"romanized_name": "Rias",
		"model_path_hash": "8538886338969864227",
		"text": "レースナちゃーん！！",
		"voice_file": "VOICE_MAIN_208_037_00793",
		"still_path_hash": "1321279492992502345",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "ひゃあっ！？",
		"voice_file": "VOICE_MAIN_001_037_00794",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "な、ななな、破廉恥な……って、リアスちゃん？",
		"voice_file": "VOICE_MAIN_001_037_00795",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "リアス",
		"romanized_name": "Rias",
		"model_path_hash": "8538886338969864227",
		"text": "はーい、リアス・アイトライゼだよ！\n驚いた？　レスナちゃん！",
		"voice_file": "VOICE_MAIN_208_037_00796",
		"still_path_hash": "1321279492992502345",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "スレイ",
		"romanized_name": "Slade",
		"model_path_hash": "1119361770767559406",
		"text": "お前な、調合中に抱きついたら危ないだろ",
		"voice_file": "VOICE_MAIN_209_037_00797",
		"still_path_hash": "5581277904703418049",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "リアス",
		"romanized_name": "Rias",
		"model_path_hash": "8538886338969864227",
		"text": "だからちゃーんと大丈夫な時に抱きついたもん",
		"voice_file": "VOICE_MAIN_208_037_00798",
		"still_path_hash": "1321279492992502345",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "ま、本当に危なそうだったら止めてたのは確かね",
		"voice_file": "VOICE_MAIN_002_037_00799",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "7061794453237574237",
		"text": "あはは、リアスは相変わらずだ",
		"voice_file": "VOICE_MAIN_048_037_00800",
		"still_path_hash": "7010833269667927555",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "リアス",
		"romanized_name": "Rias",
		"model_path_hash": "8538886338969864227",
		"text": "ヴァレリアさんとイザナさんも、\nやっほー！",
		"voice_file": "VOICE_MAIN_208_037_00801",
		"still_path_hash": "1321279492992502345",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "メーヴェ",
		"romanized_name": "Mowen",
		"model_path_hash": "8282561094361780418",
		"text": "えーっと、二人ともみんな知り合いみたいだけど……",
		"voice_file": "VOICE_MAIN_235_037_00802",
		"still_path_hash": "7917604627487944706",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "スレイ",
		"romanized_name": "Slade",
		"model_path_hash": "1119361770767559406",
		"text": "ああ、はじめまして。スレイ・クロスリッターと\n申します。あなたは……",
		"voice_file": "VOICE_MAIN_209_037_00803",
		"still_path_hash": "5581277904703418049",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "メーヴェ",
		"romanized_name": "Mowen",
		"model_path_hash": "8282561094361780418",
		"text": "私、レスナの縁者、親類にあたるメーヴェと申します",
		"voice_file": "VOICE_MAIN_235_037_00804",
		"still_path_hash": "7917604627487944706",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "もう、お母さん。面食いなんだから……",
		"voice_file": "VOICE_MAIN_001_037_00805",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 15,
		"localized_name": "スレイ",
		"romanized_name": "Slade",
		"model_path_hash": "1119361770767559406",
		"text": "お、お母さん……？",
		"voice_file": "VOICE_MAIN_209_037_00806",
		"still_path_hash": "5581277904703418049",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 16,
		"localized_name": "メーヴェ",
		"romanized_name": "Mowen",
		"model_path_hash": "8282561094361780418",
		"text": "違います、お姉さんです。\nところでスレイさん、この後二人でお茶でも……",
		"voice_file": "VOICE_MAIN_235_037_00807",
		"still_path_hash": "7917604627487944706",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 17,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "おかーさん……",
		"voice_file": "VOICE_MAIN_001_037_00808",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 18,
		"localized_name": "リアス",
		"romanized_name": "Rias",
		"model_path_hash": "8538886338969864227",
		"text": "まさかの、友達のお母さんがライバルに……？",
		"voice_file": "VOICE_MAIN_208_037_00809",
		"still_path_hash": "1321279492992502345",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 19,
		"localized_name": "スレイ",
		"romanized_name": "Slade",
		"model_path_hash": "1119361770767559406",
		"text": "リアスも真に受けるな、どう見ても冗談だ",
		"voice_file": "VOICE_MAIN_209_037_00810",
		"still_path_hash": "5581277904703418049",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 20,
		"localized_name": "メーヴェ",
		"romanized_name": "Mowen",
		"model_path_hash": "8282561094361780418",
		"text": "そうそう、冗談よ冗談。私にはユリウスっていう\n最高の旦那様がいるんだから！",
		"voice_file": "VOICE_MAIN_235_037_00811",
		"still_path_hash": "7917604627487944706",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 21,
		"localized_name": "スレイ",
		"romanized_name": "Slade",
		"model_path_hash": "1119361770767559406",
		"text": "な、ノロケのダシにされただけだ",
		"voice_file": "VOICE_MAIN_209_037_00812",
		"still_path_hash": "5581277904703418049",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 22,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "落ち着きのない母ですみません……",
		"voice_file": "VOICE_MAIN_001_037_00813",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 23,
		"localized_name": "メーヴェ",
		"romanized_name": "Mowen",
		"model_path_hash": "8282561094361780418",
		"text": "どっちが母か分からないわね、これじゃ。\nで、見たところ、錬金術士仲間って感じ？",
		"voice_file": "VOICE_MAIN_235_037_00814",
		"still_path_hash": "7917604627487944706",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 24,
		"localized_name": "スレイ",
		"romanized_name": "Slade",
		"model_path_hash": "1119361770767559406",
		"text": "俺は違います。錬金術士なのはリアスのほうです",
		"voice_file": "VOICE_MAIN_209_037_00815",
		"still_path_hash": "5581277904703418049",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 25,
		"localized_name": "リアス",
		"romanized_name": "Rias",
		"model_path_hash": "8538886338969864227",
		"text": "レスナちゃんにはあたしたちの生まれ故郷、\nハルフェンを救うのを助けてもらったんです",
		"voice_file": "VOICE_MAIN_208_037_00816",
		"still_path_hash": "1321279492992502345",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 26,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "うん。その後も文通してたんだけど、今は――",
		"voice_file": "VOICE_MAIN_001_037_00817",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 27,
		"localized_name": "リアス",
		"romanized_name": "Rias",
		"model_path_hash": "8538886338969864227",
		"text": "ハルフェンも一人前になったから、\nあたしたちもレスナちゃんの助けになれたらなって！",
		"voice_file": "VOICE_MAIN_208_037_00818",
		"still_path_hash": "1321279492992502345",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 28,
		"localized_name": "メーヴェ",
		"romanized_name": "Mowen",
		"model_path_hash": "8282561094361780418",
		"text": "あら、そうだったの。\nリアスちゃんもスレイくんも、ありがとね",
		"voice_file": "VOICE_MAIN_235_037_00819",
		"still_path_hash": "7917604627487944706",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 29,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "7061794453237574237",
		"text": "二人は今日、どうしてここに？",
		"voice_file": "VOICE_MAIN_048_037_00820",
		"still_path_hash": "7010833269667927555",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 30,
		"localized_name": "リアス",
		"romanized_name": "Rias",
		"model_path_hash": "8538886338969864227",
		"text": "ふっふっふ。それはね～……",
		"voice_file": "VOICE_MAIN_208_037_00821",
		"still_path_hash": "1321279492992502345",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 31,
		"localized_name": "スレイ",
		"romanized_name": "Slade",
		"model_path_hash": "1119361770767559406",
		"text": "実は、俺たちで「九偉人図」について調べていたら、\n意外なほど近くに手掛かりを見つけたんだ",
		"voice_file": "VOICE_MAIN_209_037_00822",
		"still_path_hash": "5581277904703418049",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 32,
		"localized_name": "スレイ",
		"romanized_name": "Slade",
		"model_path_hash": "1119361770767559406",
		"text": "ハルフェン近郊の、九偉人伝承が強く残る地域。\nそこを調査したところ……",
		"voice_file": "VOICE_MAIN_209_037_00823",
		"still_path_hash": "5581277904703418049",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 33,
		"localized_name": "リアス",
		"romanized_name": "Rias",
		"model_path_hash": "8538886338969864227",
		"text": "聖地って言われる洞窟があったの。\n一緒に探検に行こうよ！",
		"voice_file": "VOICE_MAIN_208_037_00824",
		"still_path_hash": "1321279492992502345",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 34,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "う、うん……！　もし「九偉人図」がそこにあれば、\nいよいよ９枚揃う……！",
		"voice_file": "VOICE_MAIN_001_037_00825",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 35,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "ありがとう！　リアスちゃん、スレイさん！",
		"voice_file": "VOICE_MAIN_001_037_00826",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 36,
		"localized_name": "リアス",
		"romanized_name": "Rias",
		"model_path_hash": "8538886338969864227",
		"text": "お役に立てた感じ？　いぇーい！",
		"voice_file": "VOICE_MAIN_208_037_00827",
		"still_path_hash": "1321279492992502345",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 37,
		"localized_name": "メーヴェ",
		"romanized_name": "Mowen",
		"model_path_hash": "8282561094361780418",
		"text": "いぇーい！",
		"voice_file": "VOICE_MAIN_235_037_00828",
		"still_path_hash": "7917604627487944706",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 38,
		"localized_name": "スレイ",
		"romanized_name": "Slade",
		"model_path_hash": "1119361770767559406",
		"text": "……すごく、元気なお母さんですね",
		"voice_file": "VOICE_MAIN_209_037_00829",
		"still_path_hash": "5581277904703418049",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 39,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "重ね重ね、母が、すみません……",
		"voice_file": "VOICE_MAIN_001_037_00830",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 40,
		"localized_name": "リアス・アイトライゼ",
		"romanized_name": "Rias Eidreise",
		"model_path_hash": "0",
		"text": "人懐っこい性格の元気な冒険者。\nレスナから錬金術を教わったことがある",
		"voice_file": "",
		"still_path_hash": "1321279492992502345",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 41,
		"localized_name": "スレイ・クロスリッター",
		"romanized_name": "Slade Clauslyter",
		"model_path_hash": "0",
		"text": "落ち着いた物腰のしっかり者の青年。\nリアスの同居人で、レスナたちとは知り合い",
		"voice_file": "",
		"still_path_hash": "5581277904703418049",
		"speech_balloon_type_id": 780292254
	}
]