[
	{
		"id": 0,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "こんにちはー！　今日は拙者らのライブに\n来てくれて、ありがとうございます！",
		"voice_file": "VOICE_MAIN_181_504_00344",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "イザナ/ヨハナ",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "ありがとうございます！",
		"voice_file": "VOICE_MAIN_048_504_00345",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "不要",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "ありがとうございます",
		"voice_file": "VOICE_MAIN_004_504_00346",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "拙者ら三人合わせて――",
		"voice_file": "VOICE_MAIN_181_504_00347",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "三人",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "『Ｃｕｔｉｅ☆ＡｎｉｍａＬ』です！\nよろしくお願いします！",
		"voice_file": "VOICE_MAIN_048_504_00348",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "不要",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "『Ｃｕｔｉｅ☆ＡｎｉｍａＬ』です。\nよろしくお願いします",
		"voice_file": "VOICE_MAIN_004_504_00349",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "不要",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "『Ｃｕｔｉｅ☆ＡｎｉｍａＬ』です！\nよろしくお願いします！",
		"voice_file": "VOICE_MAIN_181_504_00350",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "拙者らのこと、初めて見るよって方が多いと\n思いますので、自己紹介させていただきまする！",
		"voice_file": "VOICE_MAIN_181_504_00351",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "コンコン！　貴殿の心にお邪魔しまする！",
		"voice_file": "VOICE_MAIN_181_504_00352",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "609796561237155831",
		"text": "いらっしゃーい！",
		"voice_file": "VOICE_MAIN_001_504_00353",
		"still_path_hash": "6580594669171159823",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "天真爛漫な弟",
		"romanized_name": "Tim",
		"model_path_hash": "9091556145679123684",
		"text": "い、いらっしゃーい……！",
		"voice_file": "VOICE_MAIN_604_504_00354",
		"still_path_hash": "6387934691877097610",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "キツネの鬼門にございます！　以後、よしなに！",
		"voice_file": "VOICE_MAIN_181_504_00355",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "心配性の兄",
		"romanized_name": "Geron",
		"model_path_hash": "9151749121035711876",
		"text": "ティム。もっと大きな声を出さないと、\n彼女たちに届かないぞ",
		"voice_file": "VOICE_MAIN_003_504_00356",
		"still_path_hash": "8725176872512870759",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "天真爛漫な弟",
		"romanized_name": "Tim",
		"model_path_hash": "9091556145679123684",
		"text": "うう……でも、やっぱりまだちょっと恥ずかしいよ",
		"voice_file": "VOICE_MAIN_604_504_00357",
		"still_path_hash": "6387934691877097610",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "心配性の兄",
		"romanized_name": "Geron",
		"model_path_hash": "9151749121035711876",
		"text": "まったく。見ていろティム。こうやるんだ",
		"voice_file": "VOICE_MAIN_003_504_00358",
		"still_path_hash": "8725176872512870759",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 15,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "絶対一番、ナンバーワン！　ハムスターのヨハナよ",
		"voice_file": "VOICE_MAIN_004_504_00359",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 16,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "609796561237155831",
		"text": "よっ！　一番星！",
		"voice_file": "VOICE_MAIN_001_504_00360",
		"still_path_hash": "6580594669171159823",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 17,
		"localized_name": "心配性の兄",
		"romanized_name": "Geron",
		"model_path_hash": "9151749121035711876",
		"text": "よっ！　一番星ぃいいい！！！",
		"voice_file": "VOICE_MAIN_003_504_00361",
		"still_path_hash": "8725176872512870759",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 18,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "！　……ネズミじゃないから、覚えておいて。よろしく",
		"voice_file": "VOICE_MAIN_004_504_00362",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 19,
		"localized_name": "心配性の兄",
		"romanized_name": "Geron",
		"model_path_hash": "9151749121035711876",
		"text": "彼女たちだって頑張ってあそこに立って、\n大声を出しているんだ",
		"voice_file": "VOICE_MAIN_003_504_00363",
		"still_path_hash": "8725176872512870759",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 20,
		"localized_name": "心配性の兄",
		"romanized_name": "Geron",
		"model_path_hash": "9151749121035711876",
		"text": "当たり前のようにやっているように見えるが、\n俺たちと変わらない一人の人間",
		"voice_file": "VOICE_MAIN_003_504_00364",
		"still_path_hash": "8725176872512870759",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 21,
		"localized_name": "心配性の兄",
		"romanized_name": "Geron",
		"model_path_hash": "9151749121035711876",
		"text": "頑張っている子を応援することの、何が恥ずかしい",
		"voice_file": "VOICE_MAIN_003_504_00365",
		"still_path_hash": "8725176872512870759",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 22,
		"localized_name": "天真爛漫な弟",
		"romanized_name": "Tim",
		"model_path_hash": "9091556145679123684",
		"text": "……！　そ、そうだね……！",
		"voice_file": "VOICE_MAIN_604_504_00366",
		"still_path_hash": "6387934691877097610",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 23,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "ねこじゃらしよりハンマー！",
		"voice_file": "VOICE_MAIN_048_504_00367",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 24,
		"localized_name": "みんな",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "ハンマー！",
		"voice_file": "VOICE_MAIN_001_504_00368",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 25,
		"localized_name": "不要",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "ハンマー！",
		"voice_file": "VOICE_MAIN_181_504_00369",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 26,
		"localized_name": "不要",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "ハンマー！",
		"voice_file": "VOICE_MAIN_604_504_00370",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 27,
		"localized_name": "不要",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "ハンマー！",
		"voice_file": "VOICE_MAIN_003_504_00371",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 28,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "イザナだよ！　よろしくね！",
		"voice_file": "VOICE_MAIN_048_504_00372",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 29,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "『Ｃｕｔｉｅ☆ＡｎｉｍａＬ』の２ｎｄライブ、\nぜひ楽しんでいってくだされ！",
		"voice_file": "VOICE_MAIN_181_504_00373",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 30,
		"localized_name": "三人",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "ありがとうございました！",
		"voice_file": "VOICE_MAIN_048_504_00374",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 31,
		"localized_name": "不要",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "ありがとうございました！",
		"voice_file": "VOICE_MAIN_004_504_00375",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 32,
		"localized_name": "不要",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "ありがとうございました！",
		"voice_file": "VOICE_MAIN_181_504_00376",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 33,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "609796561237155831",
		"text": "はぁ～！　すっごく楽しかったー！\nライブからしか得られない栄養素が確実にある……！",
		"voice_file": "VOICE_MAIN_001_504_00377",
		"still_path_hash": "6580594669171159823",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 34,
		"localized_name": "オタク弟",
		"romanized_name": "Tim",
		"model_path_hash": "9091556145679123684",
		"text": "次のライブ、いつかな？\nもっとコールを覚えて、盛り上げるんだ！",
		"voice_file": "VOICE_MAIN_604_504_00378",
		"still_path_hash": "6387934691877097610",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 35,
		"localized_name": "オタク兄",
		"romanized_name": "Geron",
		"model_path_hash": "9151749121035711876",
		"text": "ああ。また次のライブも必ず来よう。\nこの調子なら、きっとすぐ大きい箱になるだろうな",
		"voice_file": "VOICE_MAIN_003_504_00379",
		"still_path_hash": "8725176872512870759",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 36,
		"localized_name": "？？？",
		"romanized_name": "???",
		"model_path_hash": "0",
		"text": "……私たちも頑張らなきゃ",
		"voice_file": "VOICE_MAIN_200_504_00380",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	}
]