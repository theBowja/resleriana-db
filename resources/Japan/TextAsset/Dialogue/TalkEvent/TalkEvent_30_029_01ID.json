[
	{
		"id": 0,
		"localized_name": "ヌルスラの鷹",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "そうだ、俺が「ヌルスラの鷹」だよ。",
		"voice_file": "VOICE_MAIN_710_036_01039",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "ヌルスラの鷹",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "同郷相手に戦いたくはねえが――",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "ヌルスラの鷹",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "知られたからには……",
		"voice_file": "VOICE_MAIN_710_036_01040",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "ヌルスラの鷹",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "無事に返すわけにはいかない",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "タイニー",
		"romanized_name": "Tiny",
		"model_path_hash": "2428915022803462192",
		"text": "っ！！",
		"voice_file": "VOICE_MAIN_221_036_01041",
		"still_path_hash": "5609327809530807165",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "ヌルスラの鷹",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "お前ら、やっちまいな！",
		"voice_file": "VOICE_MAIN_710_036_01042",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "タイニー",
		"romanized_name": "Tiny",
		"model_path_hash": "2428915022803462192",
		"text": "このっ！",
		"voice_file": "VOICE_MAIN_221_036_01043",
		"still_path_hash": "5609327809530807165",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "魔物",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "！！",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "タイニー",
		"romanized_name": "Tiny",
		"model_path_hash": "2428915022803462192",
		"text": "わっ……！　たあっ！",
		"voice_file": "VOICE_MAIN_221_036_01045",
		"still_path_hash": "5609327809530807165",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "タイニー",
		"romanized_name": "Tiny",
		"model_path_hash": "2428915022803462192",
		"text": "ま、まだっ！",
		"voice_file": "VOICE_MAIN_221_036_01046",
		"still_path_hash": "5609327809530807165",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "タイニー",
		"romanized_name": "Tiny",
		"model_path_hash": "2428915022803462192",
		"text": "やあああっ！！！",
		"voice_file": "VOICE_MAIN_221_036_01047",
		"still_path_hash": "5609327809530807165",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "タイニー",
		"romanized_name": "Tiny",
		"model_path_hash": "2428915022803462192",
		"text": "はあ、はあ、はあ……",
		"voice_file": "VOICE_MAIN_221_036_01048",
		"still_path_hash": "5609327809530807165",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "ヌルスラの鷹",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "ほう、全部倒したか",
		"voice_file": "VOICE_MAIN_710_036_01049",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "ヌルスラの鷹",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "じゃあ、おかわりだ",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "タイニー",
		"romanized_name": "Tiny",
		"model_path_hash": "2428915022803462192",
		"text": "うう……",
		"voice_file": "VOICE_MAIN_221_036_01050",
		"still_path_hash": "5609327809530807165",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 15,
		"localized_name": "ヌルスラの鷹",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "存分にくらえや",
		"voice_file": "VOICE_MAIN_710_036_01051",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 16,
		"localized_name": "タイニー",
		"romanized_name": "Tiny",
		"model_path_hash": "2428915022803462192",
		"text": "やっ！",
		"voice_file": "VOICE_MAIN_221_036_01052",
		"still_path_hash": "5609327809530807165",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 17,
		"localized_name": "タイニー",
		"romanized_name": "Tiny",
		"model_path_hash": "2428915022803462192",
		"text": "あ、ぐっ……！",
		"voice_file": "VOICE_MAIN_221_036_01053",
		"still_path_hash": "5609327809530807165",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 18,
		"localized_name": "タイニー",
		"romanized_name": "Tiny",
		"model_path_hash": "2428915022803462192",
		"text": "負け、ないっ……悪い人に、負けてたまるかっ！",
		"voice_file": "VOICE_MAIN_221_036_01054",
		"still_path_hash": "5609327809530807165",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 19,
		"localized_name": "？？？",
		"romanized_name": "???",
		"model_path_hash": "5033911810886101706",
		"text": "よく言ったな",
		"voice_file": "VOICE_MAIN_222_036_01055",
		"still_path_hash": "532943395044460292",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 20,
		"localized_name": "タイニー",
		"romanized_name": "Tiny",
		"model_path_hash": "2428915022803462192",
		"text": "えっ……？",
		"voice_file": "VOICE_MAIN_221_036_01056",
		"still_path_hash": "5609327809530807165",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 21,
		"localized_name": "エルス",
		"romanized_name": "Els",
		"model_path_hash": "5033911810886101706",
		"text": "ふっ",
		"voice_file": "VOICE_MAIN_222_036_01057",
		"still_path_hash": "532943395044460292",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 22,
		"localized_name": "ヌルスラの鷹",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "なんだ！？　くそ、やっちまえ！",
		"voice_file": "VOICE_MAIN_710_036_01058",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 23,
		"localized_name": "エルス",
		"romanized_name": "Els",
		"model_path_hash": "5033911810886101706",
		"text": "はあっ！！",
		"voice_file": "VOICE_MAIN_222_036_01059",
		"still_path_hash": "532943395044460292",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 24,
		"localized_name": "タイニー",
		"romanized_name": "Tiny",
		"model_path_hash": "2428915022803462192",
		"text": "ごめんなさい、ボス……どこかで連絡するべきでした",
		"voice_file": "VOICE_MAIN_221_036_01060",
		"still_path_hash": "5609327809530807165",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 25,
		"localized_name": "エルス",
		"romanized_name": "Els",
		"model_path_hash": "5033911810886101706",
		"text": "説教は後だ",
		"voice_file": "VOICE_MAIN_222_036_01061",
		"still_path_hash": "532943395044460292",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 26,
		"localized_name": "エルス",
		"romanized_name": "Els",
		"model_path_hash": "0",
		"text": "よく一人で持ちこたえたな",
		"voice_file": "",
		"still_path_hash": "532943395044460292",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 27,
		"localized_name": "ヌルスラの鷹",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "こんなとこで終わるわけにはいかねぇ……！",
		"voice_file": "VOICE_MAIN_710_036_01062",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 28,
		"localized_name": "エルス",
		"romanized_name": "Els",
		"model_path_hash": "5033911810886101706",
		"text": "「ヌルスラの鷹」、公務執行妨害の現行犯で逮捕する",
		"voice_file": "VOICE_MAIN_222_036_01063",
		"still_path_hash": "532943395044460292",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 29,
		"localized_name": "エルス",
		"romanized_name": "Els",
		"model_path_hash": "0",
		"text": "大人しくお縄につけ……と言いたいところだが",
		"voice_file": "",
		"still_path_hash": "532943395044460292",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 30,
		"localized_name": "エルス",
		"romanized_name": "Els",
		"model_path_hash": "5033911810886101706",
		"text": "好きなだけ抵抗しても構わない",
		"voice_file": "VOICE_MAIN_222_036_01064",
		"still_path_hash": "532943395044460292",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 31,
		"localized_name": "エルス",
		"romanized_name": "Els",
		"model_path_hash": "0",
		"text": "むしろそのほうが、こちらも正当防衛が成立するからな",
		"voice_file": "",
		"still_path_hash": "532943395044460292",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 32,
		"localized_name": "エルス",
		"romanized_name": "Els",
		"model_path_hash": "5033911810886101706",
		"text": "部下をかわいがってくれた分、容赦はしない！",
		"voice_file": "VOICE_MAIN_222_036_01065",
		"still_path_hash": "532943395044460292",
		"speech_balloon_type_id": 780292254
	}
]