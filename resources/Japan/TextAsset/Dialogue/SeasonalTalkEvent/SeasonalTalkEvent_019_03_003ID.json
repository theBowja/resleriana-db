[
	{
		"id": 0,
		"localized_name": "ララ",
		"romanized_name": "Lara",
		"model_path_hash": "4015600840793749786",
		"text": "皆、集まっていますわね",
		"voice_file": "VOICE_MAIN_005_504_01003",
		"still_path_hash": "803162819272915998",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "番号ー！　いち！",
		"voice_file": "VOICE_MAIN_048_504_01004",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "点呼しなくても見れば分かるでしょうが",
		"voice_file": "VOICE_MAIN_004_504_01005",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "ララ",
		"romanized_name": "Lara",
		"model_path_hash": "4015600840793749786",
		"text": "昨夜、カウントダウンフェスの本番で披露する\n新曲が上がってきましたわ",
		"voice_file": "VOICE_MAIN_005_504_01006",
		"still_path_hash": "803162819272915998",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "えっ、新曲！？",
		"voice_file": "VOICE_MAIN_048_504_01007",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "いつの間に！？",
		"voice_file": "VOICE_MAIN_181_504_01008",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "ララ",
		"romanized_name": "Lara",
		"model_path_hash": "4015600840793749786",
		"text": "フェスの出演権を得たときのために\n事前に準備を進めておいたのですわ",
		"voice_file": "VOICE_MAIN_005_504_01009",
		"still_path_hash": "803162819272915998",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "ララ",
		"romanized_name": "Lara",
		"model_path_hash": "4015600840793749786",
		"text": "本番まで時間は限られていますが……やれますわね？",
		"voice_file": "VOICE_MAIN_005_504_01010",
		"still_path_hash": "803162819272915998",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "当たり前でしょ",
		"voice_file": "VOICE_MAIN_004_504_01011",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "お任せくだされ！",
		"voice_file": "VOICE_MAIN_181_504_01012",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "新曲楽しみー！",
		"voice_file": "VOICE_MAIN_048_504_01013",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "ララ",
		"romanized_name": "Lara",
		"model_path_hash": "4015600840793749786",
		"text": "ふふ、期待していますわよ",
		"voice_file": "VOICE_MAIN_005_504_01014",
		"still_path_hash": "803162819272915998",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "ララ",
		"romanized_name": "Lara",
		"model_path_hash": "4015600840793749786",
		"text": "ん？　……あら",
		"voice_file": "VOICE_MAIN_005_504_01015",
		"still_path_hash": "803162819272915998",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "……本番までは残り１週間ほど。\n早速練習に取りかからねば！",
		"voice_file": "VOICE_MAIN_181_504_01016",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "まずは中身を聞いてみないと……",
		"voice_file": "VOICE_MAIN_004_504_01017",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 15,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "どんな曲なんだろう！　なんかワクワクするね！",
		"voice_file": "VOICE_MAIN_048_504_01018",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 16,
		"localized_name": "ララ",
		"romanized_name": "Lara",
		"model_path_hash": "4015600840793749786",
		"text": "ええっ！？",
		"voice_file": "VOICE_MAIN_005_504_01019",
		"still_path_hash": "803162819272915998",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 17,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "…………？",
		"voice_file": "VOICE_MAIN_181_504_01020",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 18,
		"localized_name": "ララ",
		"romanized_name": "Lara",
		"model_path_hash": "4015600840793749786",
		"text": "ええ……ええ。なるほど、状況は分かりました。\nでは、詳しいことは後ほど……",
		"voice_file": "VOICE_MAIN_005_504_01021",
		"still_path_hash": "803162819272915998",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 19,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "どうしたの？　急に大声出して",
		"voice_file": "VOICE_MAIN_004_504_01022",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 20,
		"localized_name": "ララ",
		"romanized_name": "Lara",
		"model_path_hash": "4015600840793749786",
		"text": "……あまり良くないお知らせですわ",
		"voice_file": "VOICE_MAIN_005_504_01023",
		"still_path_hash": "803162819272915998",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 21,
		"localized_name": "ララ",
		"romanized_name": "Lara",
		"model_path_hash": "4015600840793749786",
		"text": "カウントダウンフェスの会場が、局所的な大雪に\n見舞われ、復旧までしばらくかかるそうです",
		"voice_file": "VOICE_MAIN_005_504_01024",
		"still_path_hash": "803162819272915998",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 22,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "なんと！？",
		"voice_file": "VOICE_MAIN_181_504_01025",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 23,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "しばらくって、どれくらい？",
		"voice_file": "VOICE_MAIN_048_504_01026",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 24,
		"localized_name": "ララ",
		"romanized_name": "Lara",
		"model_path_hash": "4015600840793749786",
		"text": "あくまで予想の段階ですが、\n最低ひと月はかかるのではないか、と……",
		"voice_file": "VOICE_MAIN_005_504_01027",
		"still_path_hash": "803162819272915998",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 25,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "え……",
		"voice_file": "VOICE_MAIN_181_504_01028",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 26,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "それじゃ本番に間に合わないじゃない！",
		"voice_file": "VOICE_MAIN_004_504_01029",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 27,
		"localized_name": "ララ",
		"romanized_name": "Lara",
		"model_path_hash": "4015600840793749786",
		"text": "一応、別の会場を手配しようとはしているようですが、\n時期が時期ですから、難航しているようですわね",
		"voice_file": "VOICE_MAIN_005_504_01030",
		"still_path_hash": "803162819272915998",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 28,
		"localized_name": "ララ",
		"romanized_name": "Lara",
		"model_path_hash": "4015600840793749786",
		"text": "……残念ながら、\n今のところは中止する方向で動いている、と",
		"voice_file": "VOICE_MAIN_005_504_01031",
		"still_path_hash": "803162819272915998",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 29,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "そんなあ……せっかく出られることになったのに",
		"voice_file": "VOICE_MAIN_048_504_01032",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 30,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "でも、そういう事情じゃ仕方ないか……フェスの\nおかげで名前は売れたんだし、またチャンスはあるわ",
		"voice_file": "VOICE_MAIN_004_504_01033",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 31,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "そうだね！　また来年出られるかも！",
		"voice_file": "VOICE_MAIN_048_504_01034",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 32,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "来年はもっともっと売れて、\n今度はオファー枠で出てやろうじゃないの",
		"voice_file": "VOICE_MAIN_004_504_01035",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 33,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "0",
		"text": "…………",
		"voice_file": "VOICE_MAIN_181_504_01036",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	}
]