[
	{
		"id": 0,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "0",
		"text": "（アイドルとして、成し遂げたい夢……）",
		"voice_file": "VOICE_MAIN_048_504_00254",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "0",
		"text": "（アタシはどうしてアイドルになりたいって\n　思ったんだっけ）",
		"voice_file": "VOICE_MAIN_048_504_00255",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "609796561237155831",
		"text": "アイドルって素晴らしいですね……！\n見ていると、心が躍ります！　元気になります！",
		"voice_file": "VOICE_MAIN_001_504_00256",
		"still_path_hash": "6580594669171159823",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "0",
		"text": "（レスナちゃんが、楽しそうにしてたから）",
		"voice_file": "VOICE_MAIN_048_504_00257",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "609796561237155831",
		"text": "頑張れ、イザナちゃん！\n応援してるよー！",
		"voice_file": "VOICE_MAIN_001_504_00258",
		"still_path_hash": "6580594669171159823",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "0",
		"text": "（レスナちゃんが、応援してくれたから）",
		"voice_file": "VOICE_MAIN_048_504_00259",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "609796561237155831",
		"text": "イザナちゃん、みんな！　とっても良かったよ！\n私もすっごく楽しかった！",
		"voice_file": "VOICE_MAIN_001_504_00260",
		"still_path_hash": "6580594669171159823",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "0",
		"text": "（レスナちゃんが、見てくれたから）",
		"voice_file": "VOICE_MAIN_048_504_00261",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "0",
		"text": "（レスナちゃんにアタシを見てほしくて、\n　レスナちゃんの期待に応えたくて、アタシは――）",
		"voice_file": "VOICE_MAIN_048_504_00262",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "0",
		"text": "（でも、本当にそれだけ？）",
		"voice_file": "VOICE_MAIN_048_504_00263",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "0",
		"text": "（ライブすっごく楽しかった。\n　アタシ、アイドルをとっても楽しんでた）",
		"voice_file": "VOICE_MAIN_048_504_00264",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "0",
		"text": "（この楽しさを、\n　世界中のみーんなに伝えたいなって思ったんだ！）",
		"voice_file": "VOICE_MAIN_048_504_00265",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "アイドルとしてのアタシの夢、それは――",
		"voice_file": "VOICE_MAIN_048_504_00266",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "ねぇ二人とも！　２ｎｄライブに向けて、\nアタシから提案があるんだけど！",
		"voice_file": "VOICE_MAIN_048_504_00267",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "おおっ？　なんでございますか？",
		"voice_file": "VOICE_MAIN_181_504_00268",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 15,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "みんなで宣伝のためにチラシ配りをしよう！",
		"voice_file": "VOICE_MAIN_048_504_00269",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 16,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "……チラシ配り？",
		"voice_file": "VOICE_MAIN_004_504_00270",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 17,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "うん！　１ｓｔライブのお客さんが少なかったのって、\nライブがあるって知らなかったからだと思うんだ",
		"voice_file": "VOICE_MAIN_048_504_00271",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 18,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "だから、明後日ここでライブがありますよーって、\nみんなでチラシを配って宣伝しようよ！",
		"voice_file": "VOICE_MAIN_048_504_00272",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 19,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "次はもっとたくさんお客さんを呼びたいから！\nそれでアタシたちのライブを楽しんでもらいたいから！",
		"voice_file": "VOICE_MAIN_048_504_00273",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 20,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "……どうかな？",
		"voice_file": "VOICE_MAIN_048_504_00274",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 21,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "いいでござるな！　早速チラシを用意いたしましょう！\n拙者の忍術で配りまくるでござる！",
		"voice_file": "VOICE_MAIN_181_504_00275",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 22,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "チラシ配りだなんて、前時代的ね……",
		"voice_file": "VOICE_MAIN_004_504_00276",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 23,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "でも、やるわ。集客の基本は足よね",
		"voice_file": "VOICE_MAIN_004_504_00277",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 24,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "やったあ！　よーし、みんな頑張ろー！",
		"voice_file": "VOICE_MAIN_048_504_00278",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	}
]