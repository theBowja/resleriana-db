[
	{
		"id": 0,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "7061794453237574237",
		"text": "あっ……あのハートの形をした狼煙は……\nレース終了の合図だよ！",
		"voice_file": "",
		"still_path_hash": "7010833269667927555",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "377912885312431765",
		"text": "くぅ……！　\nこの私が先を越されるなんて！",
		"voice_file": "",
		"still_path_hash": "6764252557264005345",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "え、どこ？　\nイザナちゃん、よく見えるね",
		"voice_file": "",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "7061794453237574237",
		"text": "えへへ、視力には自信あるからね",
		"voice_file": "",
		"still_path_hash": "7010833269667927555",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "377912885312431765",
		"text": "ふ、ふん。私だって見えてるわよ。\n……というか、いつの間にこんな遠くまで！？",
		"voice_file": "",
		"still_path_hash": "6764252557264005345",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "7061794453237574237",
		"text": "夢中で探してたらこんな奥まで来ちゃってたんだ！",
		"voice_file": "",
		"still_path_hash": "7010833269667927555",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "早く戻らなきゃ夜が終わっちゃう！",
		"voice_file": "",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "7061794453237574237",
		"text": "いっそげーっ！！",
		"voice_file": "",
		"still_path_hash": "7010833269667927555",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "はぁ、なんとか戻ってこられた……",
		"voice_file": "",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "7061794453237574237",
		"text": "あっ、見て！　\nヴァレリアたちが表彰されてるよ！",
		"voice_file": "",
		"still_path_hash": "7010833269667927555",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "377912885312431765",
		"text": "あれ、ハイディ？\n……いつの間に合流してたのよ",
		"voice_file": "",
		"still_path_hash": "6764252557264005345",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "お疲れさま～。\nいやー、すごいレースだったね",
		"voice_file": "",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "フロッケ",
		"romanized_name": "Flocke",
		"model_path_hash": "8444632684097041943",
		"text": "皆さん、無事でよかったです！",
		"voice_file": "",
		"still_path_hash": "1324369732733195994",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "レスナ、イザナ、ヨハナ。おかえり。\nどこまで行ってたの？　遅かったじゃない",
		"voice_file": "",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "あはは……そんなことより、\nハイディさん、お久しぶりです",
		"voice_file": "",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 15,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "7061794453237574237",
		"text": "家の事情っていうのは解決したの？",
		"voice_file": "",
		"still_path_hash": "7010833269667927555",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 16,
		"localized_name": "ハイディ",
		"romanized_name": "Heidi",
		"model_path_hash": "4131218363577277631",
		"text": "ばっちり。\nちょうどいい時機に戻ってこられた、かな？",
		"voice_file": "",
		"still_path_hash": "5092952616707211512",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 17,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "こちらの方は？",
		"voice_file": "",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 18,
		"localized_name": "カロリン",
		"romanized_name": "Caroline",
		"model_path_hash": "5485149628928083359",
		"text": "皆様、お初にお目にかかります。\nシスターのカロリン・ヤスベルと申します",
		"voice_file": "",
		"still_path_hash": "5434631736340677129",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 19,
		"localized_name": "カロリン",
		"romanized_name": "Caroline",
		"model_path_hash": "5485149628928083359",
		"text": "ハイディと共に旅をしていまして。\nよろしければ、私も皆様にご同行させていただきたく",
		"voice_file": "",
		"still_path_hash": "5434631736340677129",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 20,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "もちろんです！　ぜひよろしくお願いします！",
		"voice_file": "",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 21,
		"localized_name": "有力者",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "ああ、いたいた",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 22,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "あ、あなたは……\n物資の補給をお願いしていた……",
		"voice_file": "",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 23,
		"localized_name": "有力者",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "いやはや、素晴らしいものを見せてもらった",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 24,
		"localized_name": "有力者",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "そんな、優勝したお主たちに尋ねよう。\n愛とは――なんだ？",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 25,
		"localized_name": "ハイディ",
		"romanized_name": "Heidi",
		"model_path_hash": "4131218363577277631",
		"text": "……愛ってのは――",
		"voice_file": "",
		"still_path_hash": "5092952616707211512",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 26,
		"localized_name": "ハイディ",
		"romanized_name": "Heidi",
		"model_path_hash": "4131218363577277631",
		"text": "許すことかな",
		"voice_file": "",
		"still_path_hash": "5092952616707211512",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 27,
		"localized_name": "ハイディ",
		"romanized_name": "Heidi",
		"model_path_hash": "4131218363577277631",
		"text": "あとは、忘れないこと",
		"voice_file": "",
		"still_path_hash": "5092952616707211512",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 28,
		"localized_name": "有力者",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "なるほど……それもまた愛！　\n深い言葉、確かにいただいた！！",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 29,
		"localized_name": "有力者",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "お主たちの大きな愛、しかと見せてもらった！　\n我らホルハーツは今や、お主たちと愛の同志！",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 30,
		"localized_name": "有力者",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "惜しみない愛と共に、旅の協力を約束しよう！",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 31,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "やったー！　\nこれで次の島にも進めるね",
		"voice_file": "",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 32,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "本当に、ありがとうございます！",
		"voice_file": "",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 33,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "0",
		"text": "（こうして、ホルハーツでの出来事が終わり……）",
		"voice_file": "",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 34,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "0",
		"text": "（私たちの旅路に、ハイディさんとカロリンさんが\n　合流したのでした）",
		"voice_file": "",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	}
]