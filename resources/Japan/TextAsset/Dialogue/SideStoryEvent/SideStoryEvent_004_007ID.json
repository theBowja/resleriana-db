[
	{
		"id": 0,
		"localized_name": "ハイディ",
		"romanized_name": "Heidi",
		"model_path_hash": "0",
		"text": "（約束の場所はこの辺りのはずだけど……）",
		"voice_file": "",
		"still_path_hash": "120518867847693403",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "ハイディ",
		"romanized_name": "Heidi",
		"model_path_hash": "5270784299656074783",
		"text": "……銃声！？　まさか、カロリン！？",
		"voice_file": "",
		"still_path_hash": "120518867847693403",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "ハイディ",
		"romanized_name": "Heidi",
		"model_path_hash": "5270784299656074783",
		"text": "カロリン！　加勢するよ！",
		"voice_file": "",
		"still_path_hash": "120518867847693403",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "カロリン",
		"romanized_name": "Caroline",
		"model_path_hash": "5485149628928083359",
		"text": "ハイディ！　助かります",
		"voice_file": "",
		"still_path_hash": "5434631736340677129",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "カロリン",
		"romanized_name": "Caroline",
		"model_path_hash": "5485149628928083359",
		"text": "おケガはありませんか、ハイディ",
		"voice_file": "",
		"still_path_hash": "5434631736340677129",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "ハイディ",
		"romanized_name": "Heidi",
		"model_path_hash": "5270784299656074783",
		"text": "へへ、大丈夫。\nそっちこそ、派手にやるね",
		"voice_file": "",
		"still_path_hash": "120518867847693403",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "カロリン",
		"romanized_name": "Caroline",
		"model_path_hash": "5485149628928083359",
		"text": "お恥ずかしい限りです。\nつい、身体が動いてしまいまして",
		"voice_file": "",
		"still_path_hash": "5434631736340677129",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "ハイディ",
		"romanized_name": "Heidi",
		"model_path_hash": "5270784299656074783",
		"text": "……こうして会うの、\n教会で一緒にシスターをやってた頃以来だね",
		"voice_file": "",
		"still_path_hash": "120518867847693403",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "ハイディ",
		"romanized_name": "Heidi",
		"model_path_hash": "5270784299656074783",
		"text": "昔から腕っぷしは強かったけど、こんなだったっけ？　\n会わない間に人って変わるもんだなあ",
		"voice_file": "",
		"still_path_hash": "120518867847693403",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "カロリン",
		"romanized_name": "Caroline",
		"model_path_hash": "5485149628928083359",
		"text": "いえ、これもすべて己の成長の証です。\nハイディも、随分頼もしくなられましたね",
		"voice_file": "",
		"still_path_hash": "5434631736340677129",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "ハイディ",
		"romanized_name": "Heidi",
		"model_path_hash": "5270784299656074783",
		"text": "ありがと",
		"voice_file": "",
		"still_path_hash": "120518867847693403",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "ハイディ",
		"romanized_name": "Heidi",
		"model_path_hash": "5270784299656074783",
		"text": "……そうだ、これ。\nカロリンからの手紙、ちゃんと受け取ったよ",
		"voice_file": "",
		"still_path_hash": "120518867847693403",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "ハイディ",
		"romanized_name": "Heidi",
		"model_path_hash": "5270784299656074783",
		"text": "ここに書いてあったこと、本当なの？",
		"voice_file": "",
		"still_path_hash": "120518867847693403",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "カロリン",
		"romanized_name": "Caroline",
		"model_path_hash": "5485149628928083359",
		"text": "はい。嘘偽りなく、すべて事実です",
		"voice_file": "",
		"still_path_hash": "5434631736340677129",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "ハイディ",
		"romanized_name": "Heidi",
		"model_path_hash": "5270784299656074783",
		"text": "……父さんが、母さんに決闘を申し込んだって――",
		"voice_file": "",
		"still_path_hash": "120518867847693403",
		"speech_balloon_type_id": 780292254
	}
]