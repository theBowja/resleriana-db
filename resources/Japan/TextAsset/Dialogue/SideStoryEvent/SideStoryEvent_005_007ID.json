[
	{
		"id": 0,
		"localized_name": "ベスティラ王",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "むう……っ！",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "7061794453237574237",
		"text": "はあ、はあ……\nや、やった……？　勝てたの？",
		"voice_file": "",
		"still_path_hash": "7010833269667927555",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "ベスティラ王",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "……見事だ！　\nお前たちの生き様、しかと見届けたぞ！",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "リラ",
		"romanized_name": "Lila",
		"model_path_hash": "6420784340983749558",
		"text": "なんという強さだ。あれだけ攻撃を打ち込んだのに、\nピンピンしているとは……",
		"voice_file": "",
		"still_path_hash": "658330190563200680",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "ティム",
		"romanized_name": "Tim",
		"model_path_hash": "9091556145679123684",
		"text": "もしかしたら、ここで打ち止めにしたのは\n僕たちのためなのかもしれませんね……",
		"voice_file": "",
		"still_path_hash": "6387934691877097610",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "ベスティラ王",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "約束通り、「九偉人図」を譲り渡そう。\nこれがその絵だ",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "7061794453237574237",
		"text": "やったー！　\nこれでまた一歩前進だね！",
		"voice_file": "",
		"still_path_hash": "7010833269667927555",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "ありがとうございます、国王陛下！",
		"voice_file": "",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "ベスティラ王",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "こちらこそ礼を言おう。\nよくこの者たちを集めてくれた",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "ベスティラ王",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "褒美に、他の「九偉人図」の情報も教えてやろう",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "おお！　いいんすか！！",
		"voice_file": "",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "ベスティラ王",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "キノコの島、ピルッツァに住む美術品収集家が\n１枚持っているという話だ",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "ベスティラ王",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "あの男はキノコの栽培で一山当てた富豪でな。\nいつか余が買い取ろうと狙っていたのだ",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "リラ",
		"romanized_name": "Lila",
		"model_path_hash": "6420784340983749558",
		"text": "美術品収集家か。\n面倒な交渉になりそうだな",
		"voice_file": "",
		"still_path_hash": "658330190563200680",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "キノコの島……\nまた珍しい場所が出てきたっすね",
		"voice_file": "",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 15,
		"localized_name": "ベスティラ王",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "「九偉人図」は、強き者……お前たちこそが\n持つのにふさわしいのだろう",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 16,
		"localized_name": "ベスティラ王",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "この後の旅の健闘を祈っているぞ！",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 17,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "はい！　このたびは、ありがとうございました！",
		"voice_file": "",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 18,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "0",
		"text": "（こうして、ベスティラ武道会は幕を閉じました）",
		"voice_file": "",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 19,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "0",
		"text": "（その後は、九偉人との争いによって\n　慌ただしくなってしまいましたが……）",
		"voice_file": "",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 20,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "0",
		"text": "（私たちは、日を改めて打ち上げをすることに\n　なりました！）",
		"voice_file": "",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 21,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "色々あって先延ばしになってしまいましたが……\nベスティラ武道会の打ち上げをしたいと思います！",
		"voice_file": "",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 22,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "皆さん、お疲れさまでした！",
		"voice_file": "",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 23,
		"localized_name": "みんな",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "お疲れさまでしたー！",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 24,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "7061794453237574237",
		"text": "いやー、あの後は大変だったね。武道会を見て、\nアタシたちのファンになったって人が押し寄せて来てさ",
		"voice_file": "",
		"still_path_hash": "7010833269667927555",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 25,
		"localized_name": "リアス",
		"romanized_name": "Rias",
		"model_path_hash": "8538886338969864227",
		"text": "強さがすべての国だから、\nやっぱり強いとモテるんだね",
		"voice_file": "",
		"still_path_hash": "1321279492992502345",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 26,
		"localized_name": "ジェロン",
		"romanized_name": "Geron",
		"model_path_hash": "9151749121035711876",
		"text": "ティム、誰かと付き合うなら祝福するぞ",
		"voice_file": "",
		"still_path_hash": "8725176872512870759",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 27,
		"localized_name": "ジェロン",
		"romanized_name": "Geron",
		"model_path_hash": "9151749121035711876",
		"text": "もちろん、ふさわしい奴かどうかは\n兄として、しっかりと見定めさせてもらうが",
		"voice_file": "",
		"still_path_hash": "8725176872512870759",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 28,
		"localized_name": "ティム",
		"romanized_name": "Tim",
		"model_path_hash": "9091556145679123684",
		"text": "だ、大丈夫だって！　そういうのは、まだ早いから……",
		"voice_file": "",
		"still_path_hash": "6387934691877097610",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 29,
		"localized_name": "リラ",
		"romanized_name": "Lila",
		"model_path_hash": "6420784340983749558",
		"text": "しかし、悪くない経験だったな。\nこういうことがあったらまた呼んでくれ",
		"voice_file": "",
		"still_path_hash": "658330190563200680",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 30,
		"localized_name": "レイニャ",
		"romanized_name": "Lenja",
		"model_path_hash": "5067796612903841500",
		"text": "レイニャも、\n皆さんと一緒に戦えて嬉しかったです……！",
		"voice_file": "",
		"still_path_hash": "326916344881311074",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 31,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "8669110150163868408",
		"text": "拙者も忍術の精進を重ね、\n次はもっと活躍してみせまする！",
		"voice_file": "",
		"still_path_hash": "7367252523135796624",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 32,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "本当に、皆さんには感謝してもしきれません。\nささ、遠慮せずにどんどん食べてくださいね！",
		"voice_file": "",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 33,
		"localized_name": "レイニャ",
		"romanized_name": "Lenja",
		"model_path_hash": "5067796612903841500",
		"text": "食べるといえば……あの味が忘れられなくて。\n……用意してたり、しませんか……？",
		"voice_file": "",
		"still_path_hash": "326916344881311074",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 34,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "7061794453237574237",
		"text": "あー、アレかあ！\n美味しかったもんね！",
		"voice_file": "",
		"still_path_hash": "7010833269667927555",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 35,
		"localized_name": "リラ",
		"romanized_name": "Lila",
		"model_path_hash": "6420784340983749558",
		"text": "ああ。私ももう一度食べたいと思っていた",
		"voice_file": "",
		"still_path_hash": "658330190563200680",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 36,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "アレ？　なんのことでしょう？",
		"voice_file": "",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 37,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "7061794453237574237",
		"text": "レスナちゃんたちが作った携帯食料！\nすっごく美味しかったんだから！",
		"voice_file": "",
		"still_path_hash": "7010833269667927555",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 38,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "えええ！？　アレがまた食べたいの？",
		"voice_file": "",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 39,
		"localized_name": "レイニャ",
		"romanized_name": "Lenja",
		"model_path_hash": "5067796612903841500",
		"text": "はい……ここの料理も美味しいんですけど、\nどうしても、アレをもう一度食べたくて……",
		"voice_file": "",
		"still_path_hash": "326916344881311074",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 40,
		"localized_name": "イクセル",
		"romanized_name": "Yksel",
		"model_path_hash": "8416193151802436544",
		"text": "聞き捨てならねえな！\n俺の料理より美味しいものがあるって！？",
		"voice_file": "",
		"still_path_hash": "8827427841789589118",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 41,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "わっ！？　落ち着いてください！\nそんなことは一言も……",
		"voice_file": "",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 42,
		"localized_name": "イクセル",
		"romanized_name": "Yksel",
		"model_path_hash": "8416193151802436544",
		"text": "どうして錬金術士ってやつは\nいつもいつもいつもいつも！！！",
		"voice_file": "",
		"still_path_hash": "8827427841789589118",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 43,
		"localized_name": "イクセル",
		"romanized_name": "Yksel",
		"model_path_hash": "8416193151802436544",
		"text": "よーし、決めた！\n俺は、ランターナ大料理大会を開催する！",
		"voice_file": "",
		"still_path_hash": "8827427841789589118",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 44,
		"localized_name": "イクセル",
		"romanized_name": "Yksel",
		"model_path_hash": "8416193151802436544",
		"text": "勝負だレスナ！　逃げるんじゃねえぞ！",
		"voice_file": "",
		"still_path_hash": "8827427841789589118",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 45,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "えええええ！？",
		"voice_file": "",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 46,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "0",
		"text": "（どうやら……慌ただしい日々は、\n　まだまだ終わらなそうです……）",
		"voice_file": "",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	}
]