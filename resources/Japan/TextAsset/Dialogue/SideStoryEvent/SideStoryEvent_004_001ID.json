[
	{
		"id": 0,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "ここが噂の愛の島、ホルハーツか……\nなんというか、恋人っぽい人たちだらけね",
		"voice_file": "",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "ランツェ",
		"romanized_name": "Lanze",
		"model_path_hash": "845404123422268284",
		"text": "ああ。見渡す限りイチャイチャしてる奴らばっかりだ。\n若いねぇ！　こんな公衆の面前で！",
		"voice_file": "",
		"still_path_hash": "5409134969144639524",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "フロッケ",
		"romanized_name": "Flocke",
		"model_path_hash": "8444632684097041943",
		"text": "あちらの鐘の前には、たくさんの方が並んでいますね。\n何かゆかりのあるものなのでしょうか",
		"voice_file": "",
		"still_path_hash": "1324369732733195994",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "ランツェ",
		"romanized_name": "Lanze",
		"model_path_hash": "845404123422268284",
		"text": "天使ちゃんにはまだ早ぇ場所だ。\n俺がしっかり見張ってねえと……！",
		"voice_file": "",
		"still_path_hash": "5409134969144639524",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "ランツェ、過保護がすぎるわよ",
		"voice_file": "",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "ランツェ",
		"romanized_name": "Lanze",
		"model_path_hash": "845404123422268284",
		"text": "俺は父親みたいなもんなんだよ",
		"voice_file": "",
		"still_path_hash": "5409134969144639524",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "さて、レスナたちは……。私たちの到着は\nだいぶ遅れちゃったし、もう次の島へ出発したかしら？",
		"voice_file": "",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "ランツェ",
		"romanized_name": "Lanze",
		"model_path_hash": "845404123422268284",
		"text": "船の墓場の問題が解決したか、誰かしら経過を見る\n必要があったが……時間を掛けすぎたか",
		"voice_file": "",
		"still_path_hash": "5409134969144639524",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "ランツェ",
		"romanized_name": "Lanze",
		"model_path_hash": "845404123422268284",
		"text": "ま、レスナたちを先に行かせるって判断は\n間違ってなかったと思うけどな",
		"voice_file": "",
		"still_path_hash": "5409134969144639524",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "フロッケ",
		"romanized_name": "Flocke",
		"model_path_hash": "8444632684097041943",
		"text": "あっ、港のほうに、見覚えのある人影が……\nレスナさんたちです！",
		"voice_file": "",
		"still_path_hash": "1324369732733195994",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "皆様、ホルハーツへようこそ！　なーんてね。\nすごいっしょ、この島",
		"voice_file": "",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "みんな無事だったんですね、よかった……！",
		"voice_file": "",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "レスナ、まだここにいたのね。\nてっきりもう次の島へ向かったかと思ってたわ",
		"voice_file": "",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "それが実は、ちょっと事情があって……",
		"voice_file": "",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "フロッケ",
		"romanized_name": "Flocke",
		"model_path_hash": "8444632684097041943",
		"text": "事情？　どのようなものなのでしょう？",
		"voice_file": "",
		"still_path_hash": "1324369732733195994",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 15,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "物資の補給をお願いしに、\n有力者の方を訪ねたんだけど、そしたら……",
		"voice_file": "",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 16,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "そしたら？",
		"voice_file": "",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 17,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "近々「愛のレース」という催しが開かれるみたいで、\nそれで優勝したら協力してくださるって……",
		"voice_file": "",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 18,
		"localized_name": "みんな",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "「愛のレース」！？　",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 19,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "「愛のレース」……\nなかなかパンチのある響きっすけど……内容は？",
		"voice_file": "",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 20,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "詳しくはまだ聞いていないんだけれど、どうやら\n仲良しの組で参加して、愛の強さを競うみたいだよ",
		"voice_file": "",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 21,
		"localized_name": "フロッケ",
		"romanized_name": "Flocke",
		"model_path_hash": "8444632684097041943",
		"text": "フロッケたちも参加できるのでしょうか……？　",
		"voice_file": "",
		"still_path_hash": "1324369732733195994",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 22,
		"localized_name": "ランツェ",
		"romanized_name": "Lanze",
		"model_path_hash": "845404123422268284",
		"text": "ダメだダメだ！　なに言ってんだ天使ちゃん！\n俺の目が黒いうちは許しませんよ！",
		"voice_file": "",
		"still_path_hash": "5409134969144639524",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 23,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "ランツェ、もう少し落ち着きなさいってば",
		"voice_file": "",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 24,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "でも、補給のためには優勝しなきゃいけないって\nことだよね。これはやるしかないっしょ！",
		"voice_file": "",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 25,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "うん。私たちも、できる限り頑張るつもりだよ！",
		"voice_file": "",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 26,
		"localized_name": "フロッケ",
		"romanized_name": "Flocke",
		"model_path_hash": "8444632684097041943",
		"text": "みんなで力を合わせれば、きっと大丈夫です！",
		"voice_file": "",
		"still_path_hash": "1324369732733195994",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 27,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "ま、愛の強さを競うっていうのはよく分からないけど、\n私たちならなんとかなるでしょ",
		"voice_file": "",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 28,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "よーし、愛の島で一番輝く組を目指して、\nみんなで優勝しよう！",
		"voice_file": "",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 29,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "うん、頑張ろう！",
		"voice_file": "",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 30,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "それじゃ、まずはレースの詳細を調べに行きましょうか",
		"voice_file": "",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 31,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "うんうん、案内はアタシに任せて！",
		"voice_file": "",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 32,
		"localized_name": "ランツェ",
		"romanized_name": "Lanze",
		"model_path_hash": "845404123422268284",
		"text": "おい、はしゃぎすぎて迷子になるなよ",
		"voice_file": "",
		"still_path_hash": "5409134969144639524",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 33,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "レスナ、準備はいい？",
		"voice_file": "",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 34,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "もちろんだよ、ヴァレリア",
		"voice_file": "",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	}
]