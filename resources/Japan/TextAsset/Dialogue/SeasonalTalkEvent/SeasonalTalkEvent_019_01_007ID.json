[
	{
		"id": 0,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "皆様、はじめまして！",
		"voice_file": "VOICE_MAIN_181_504_00161",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "拙者らは、本日デビューの新アイドルユニット、\n『Ｃｕｔｉｅ☆ＡｎｉｍａＬ』でございまする！",
		"voice_file": "VOICE_MAIN_181_504_00162",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "三人",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "よろしくお願いします！",
		"voice_file": "VOICE_MAIN_048_504_00163",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "不要",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "よろしくお願いします",
		"voice_file": "VOICE_MAIN_004_504_00164",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "不要",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "よろしくお願いします！",
		"voice_file": "VOICE_MAIN_181_504_00165",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "いざステージに立つと緊張してきちゃった！",
		"voice_file": "VOICE_MAIN_048_504_00166",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "609796561237155831",
		"text": "頑張れ、イザナちゃん！\n応援してるよー！",
		"voice_file": "VOICE_MAIN_001_504_00167",
		"still_path_hash": "6580594669171159823",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "0",
		"text": "…………",
		"voice_file": "VOICE_MAIN_004_504_00168",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "心配性の兄",
		"romanized_name": "Geron",
		"model_path_hash": "9151749121035711876",
		"text": "……どうだ？　久しぶりの街は。\nずっと入院してたんだ。疲れたらすぐに言うんだぞ",
		"voice_file": "VOICE_MAIN_003_504_00169",
		"still_path_hash": "8725176872512870759",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "天真爛漫な弟",
		"romanized_name": "Tim",
		"model_path_hash": "9091556145679123684",
		"text": "心配しすぎだよ兄さん。もう病気は治ったんだから",
		"voice_file": "VOICE_MAIN_604_504_00170",
		"still_path_hash": "6387934691877097610",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "天真爛漫な弟",
		"romanized_name": "Tim",
		"model_path_hash": "9091556145679123684",
		"text": "あっ！　あそこ、何かやってるみたいだよ！\n見に行こうよ！",
		"voice_file": "VOICE_MAIN_604_504_00171",
		"still_path_hash": "6387934691877097610",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "心配性の兄",
		"romanized_name": "Geron",
		"model_path_hash": "9151749121035711876",
		"text": "こら、急に走るな……ん、あれは……",
		"voice_file": "VOICE_MAIN_003_504_00172",
		"still_path_hash": "8725176872512870759",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "天真爛漫な弟",
		"romanized_name": "Tim",
		"model_path_hash": "9091556145679123684",
		"text": "わあ、兄さん、あれってアイドル！？\n入院してた時に動画で見せてくれたのと同じ人？",
		"voice_file": "VOICE_MAIN_604_504_00173",
		"still_path_hash": "6387934691877097610",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "心配性の兄",
		"romanized_name": "Geron",
		"model_path_hash": "9151749121035711876",
		"text": "いや、違うみたいだが……",
		"voice_file": "VOICE_MAIN_003_504_00174",
		"still_path_hash": "8725176872512870759",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "天真爛漫な弟",
		"romanized_name": "Tim",
		"model_path_hash": "9091556145679123684",
		"text": "っ！？",
		"voice_file": "VOICE_MAIN_604_504_00175",
		"still_path_hash": "6387934691877097610",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 15,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "それではアタシたちの曲、聞いてください！",
		"voice_file": "VOICE_MAIN_048_504_00176",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 16,
		"localized_name": "三人",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "ありがとうございました！",
		"voice_file": "VOICE_MAIN_048_504_00177",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 17,
		"localized_name": "不要",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "ありがとうございました",
		"voice_file": "VOICE_MAIN_004_504_00178",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 18,
		"localized_name": "不要",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "ありがとうございました！",
		"voice_file": "VOICE_MAIN_181_504_00179",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 19,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "609796561237155831",
		"text": "イザナちゃん、みんな！　とっても良かったよ！\n私もすっごく楽しかった！",
		"voice_file": "VOICE_MAIN_001_504_00180",
		"still_path_hash": "6580594669171159823",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 20,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "ほんと！？　やったー！",
		"voice_file": "VOICE_MAIN_048_504_00181",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 21,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "客はほとんどいなかったっていうのに、\nあんたは楽しそうね……",
		"voice_file": "VOICE_MAIN_004_504_00182",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 22,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "うん！　だって、とっても楽しいから！\nレスナちゃんも楽しそうだし！",
		"voice_file": "VOICE_MAIN_048_504_00183",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 23,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "…………",
		"voice_file": "VOICE_MAIN_004_504_00184",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 24,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "今日は、拙者たちの初ライブを見てくださって\nありがとうございました！",
		"voice_file": "VOICE_MAIN_181_504_00185",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 25,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "これからどんどん頑張ってまいります。",
		"voice_file": "VOICE_MAIN_181_504_00186",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 26,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "どうぞ『Ｃｕｔｉｅ☆ＡｎｉｍａＬ』を\nよろしくお願いしまする！",
		"voice_file": "VOICE_MAIN_181_504_00187",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 27,
		"localized_name": "天真爛漫な弟",
		"romanized_name": "Tim",
		"model_path_hash": "9091556145679123684",
		"text": "あ……あのっ！",
		"voice_file": "VOICE_MAIN_604_504_00188",
		"still_path_hash": "6387934691877097610",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 28,
		"localized_name": "天真爛漫な弟",
		"romanized_name": "Tim",
		"model_path_hash": "9091556145679123684",
		"text": "ライブ、とっても楽しかったです！\n活動頑張ってください！　応援してます！",
		"voice_file": "VOICE_MAIN_604_504_00189",
		"still_path_hash": "6387934691877097610",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 29,
		"localized_name": "心配性の兄",
		"romanized_name": "Geron",
		"model_path_hash": "9151749121035711876",
		"text": "弟と共に、これからの活動を楽しみにしている",
		"voice_file": "VOICE_MAIN_003_504_00190",
		"still_path_hash": "8725176872512870759",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 30,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "～～っ！　ありがとうございまする！\nぜひ、またライブに来てくだされ！",
		"voice_file": "VOICE_MAIN_181_504_00191",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	}
]