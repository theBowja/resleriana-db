[
	{
		"id": 0,
		"localized_name": "システム",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "あれもこれもどれも",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "システム",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "素敵なＷｏｎｄｅｒｆｕｌ　Ｌｉｆｅ",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "システム",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "ねぇ　その尻尾かわいいね",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "システム",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "見て　この耳も綺麗だわ",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "システム",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "色んな好きがあれば　世界は輝くんだ",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "システム",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "さあ毛並みを整えたら",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "システム",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "楽しいこと探しに行こう",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "システム",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "きっとね　特別な未来に辿り着く",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "システム",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "よーし、今日も張り切っていっくよー！",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "システム",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "幸せ探しの術、とくとご覧あれ！",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "システム",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "やっぱり完璧美少女、私がいないと始まんない！",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "システム",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "準備はいいですか",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "システム",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "あにまる×あにまる　みんな集まれば",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "システム",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "始まる！　始まる！　夢のアドベンチャー",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "システム",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "好奇心　止まらなくて",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 15,
		"localized_name": "システム",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "ワクワクもドキドキも無限だにゃん",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 16,
		"localized_name": "システム",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "あにまる×あにまる　私たちから",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 17,
		"localized_name": "システム",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "はなまるあげちゃう　ちゃんと見ているのさ",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 18,
		"localized_name": "システム",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "頑張ってるキミに届け",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 19,
		"localized_name": "システム",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "よくできました！",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 20,
		"localized_name": "システム",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "ほら　毎日Ｗｏｎｄｅｒｆｕｌ　Ｌｉｆｅ",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	}
