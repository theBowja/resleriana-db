[
	{
		"id": 0,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "7061794453237574237",
		"text": "ふぅ……これで何人目だろ。\nさすがに汗だくだよー",
		"voice_file": "",
		"still_path_hash": "7010833269667927555",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "7061794453237574237",
		"text": "レスナちゃんたちが作ってくれた携帯食料……\nいただきます！",
		"voice_file": "",
		"still_path_hash": "7010833269667927555",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "7061794453237574237",
		"text": "美味しい～！　\nこれならまだまだ戦えそうだよ！",
		"voice_file": "",
		"still_path_hash": "7010833269667927555",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "7061794453237574237",
		"text": "さーて、次の相手は……\nっ！？",
		"voice_file": "",
		"still_path_hash": "7010833269667927555",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "リラ",
		"romanized_name": "Lila",
		"model_path_hash": "6420784340983749558",
		"text": "不意打ちは無理か",
		"voice_file": "",
		"still_path_hash": "658330190563200680",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "7061794453237574237",
		"text": "リラさん……！　\nまさか、ここで当たるなんて",
		"voice_file": "",
		"still_path_hash": "7010833269667927555",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "リラ",
		"romanized_name": "Lila",
		"model_path_hash": "6420784340983749558",
		"text": "順調なようだな、イザナ。\nだが、ここからが本番だ",
		"voice_file": "",
		"still_path_hash": "658330190563200680",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "7061794453237574237",
		"text": "うん！　アタシ、リラさんと戦えるの、\nずっと楽しみにしてたんだ！",
		"voice_file": "",
		"still_path_hash": "7010833269667927555",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "あっ、イザナちゃんとリラさんが対峙してる……！",
		"voice_file": "",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "どっちが勝つか、見ものっすね",
		"voice_file": "",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "スレイ",
		"romanized_name": "Slade",
		"model_path_hash": "1119361770767559406",
		"text": "あの二人が本気でぶつかったら、\n砂漠が吹き飛ぶんじゃないか？",
		"voice_file": "",
		"still_path_hash": "5581277904703418049",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "鏑矢",
		"romanized_name": "Kaburaya",
		"model_path_hash": "2028850221954181122",
		"text": "リラとやら、そこまでの強者であるか。\nぜひ手合わせを願いたいものだな",
		"voice_file": "",
		"still_path_hash": "3206719061125087729",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "8669110150163868408",
		"text": "リラ殿とは拙者もクロガネ島にて共闘いたしましたが、\nさすがの実力でございました",
		"voice_file": "",
		"still_path_hash": "7367252523135796624",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "リアス",
		"romanized_name": "Rias",
		"model_path_hash": "8538886338969864227",
		"text": "イザナさん、頑張れー！　リラさんを倒しちゃえー！",
		"voice_file": "",
		"still_path_hash": "1321279492992502345",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "そうだー！　頑張れイザナちゃーん！",
		"voice_file": "",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 15,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "……って、鬼門ちゃんにリアスちゃん！？\nいつの間にここに……？",
		"voice_file": "",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 16,
		"localized_name": "リアス",
		"romanized_name": "Rias",
		"model_path_hash": "8538886338969864227",
		"text": "いやー、リラさんに当たっちゃってさ、\nあっさりやられちゃったよ！　でも楽しかった～",
		"voice_file": "",
		"still_path_hash": "1321279492992502345",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 17,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "8669110150163868408",
		"text": "拙者、新作の忍術を試したところ……\n自爆してしまいまして……無念でござる",
		"voice_file": "",
		"still_path_hash": "7367252523135796624",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 18,
		"localized_name": "鏑矢",
		"romanized_name": "Kaburaya",
		"model_path_hash": "2028850221954181122",
		"text": "せっかくの舞台だというのに何をしておるのだ……",
		"voice_file": "",
		"still_path_hash": "3206719061125087729",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 19,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "忍術って、やっぱり危ないんだね……",
		"voice_file": "",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 20,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "で、でも、みんな無事でよかった！\nさあ、残りの参加者に声援を送りましょう！",
		"voice_file": "",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 21,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "イザナ、リラさん、どっちも頑張れー！",
		"voice_file": "",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 22,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "8669110150163868408",
		"text": "リラ殿、拙者の分までお力を発揮なされ！",
		"voice_file": "",
		"still_path_hash": "7367252523135796624",
		"speech_balloon_type_id": 780292254
	}
]