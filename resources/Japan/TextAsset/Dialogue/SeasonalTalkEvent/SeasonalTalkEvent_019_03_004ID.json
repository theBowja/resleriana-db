[
	{
		"id": 0,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "そんな……",
		"voice_file": "VOICE_MAIN_181_504_01037",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "どうしたの？　具合悪い？",
		"voice_file": "VOICE_MAIN_048_504_01038",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "まあ、残念なのは分かるけど……",
		"voice_file": "VOICE_MAIN_004_504_01039",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "ララ",
		"romanized_name": "Lara",
		"model_path_hash": "4015600840793749786",
		"text": "鬼門。二人には話しておいたほうがよいのではなくて？",
		"voice_file": "VOICE_MAIN_005_504_01040",
		"still_path_hash": "803162819272915998",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "……ええ。分かっておりまする",
		"voice_file": "VOICE_MAIN_181_504_01041",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "何よ、話って？",
		"voice_file": "VOICE_MAIN_004_504_01042",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "……と、いうわけなのだ",
		"voice_file": "VOICE_MAIN_181_504_01043",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "年が明けたらって……そんな急な話……！",
		"voice_file": "VOICE_MAIN_004_504_01044",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "始めたばっかりなのに……",
		"voice_file": "VOICE_MAIN_048_504_01045",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "二人とも、本当にすまない。\nだが、やむにやまれぬ事情ゆえ……",
		"voice_file": "VOICE_MAIN_181_504_01046",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "まあ、家庭の事情ならしょうがないんじゃないの……",
		"voice_file": "VOICE_MAIN_004_504_01047",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "お父さん、良くなるといいね……",
		"voice_file": "VOICE_MAIN_048_504_01048",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "ありがとう",
		"voice_file": "VOICE_MAIN_181_504_01049",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "本来ならば、今度のフェスで花道を飾ろうと\n思っていたのだが……それも叶わなくなってしまったな",
		"voice_file": "VOICE_MAIN_181_504_01050",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "っ……！",
		"voice_file": "VOICE_MAIN_048_504_01051",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 15,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "ねえ社長！　どうにかならないの！？",
		"voice_file": "VOICE_MAIN_048_504_01052",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 16,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "そうよ！　辞めるのは仕方なかったとしても……\nこのまま何もなく終わるなんて嫌よ！",
		"voice_file": "VOICE_MAIN_004_504_01053",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 17,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "二人とも……ありがとう。\nその気持ちだけで拙者は……",
		"voice_file": "VOICE_MAIN_181_504_01054",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 18,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "あんたも！　なに最初から諦めてんのよ！",
		"voice_file": "VOICE_MAIN_004_504_01055",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 19,
		"localized_name": "ララ",
		"romanized_name": "Lara",
		"model_path_hash": "4015600840793749786",
		"text": "……ええ。わたくしも同じ気持ちですわ",
		"voice_file": "VOICE_MAIN_005_504_01056",
		"still_path_hash": "803162819272915998",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 20,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "アタシたちだけでもちゃんとライブとかできないかな！",
		"voice_file": "VOICE_MAIN_048_504_01057",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 21,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "会場の確保は難しいかもしれないけど……\nネット配信って手もあるわよ",
		"voice_file": "VOICE_MAIN_004_504_01058",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 22,
		"localized_name": "ララ",
		"romanized_name": "Lara",
		"model_path_hash": "4015600840793749786",
		"text": "まあ、そちらは最終手段ですわね。\nそれよりもまずは……",
		"voice_file": "VOICE_MAIN_005_504_01059",
		"still_path_hash": "803162819272915998",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 23,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "まずは？",
		"voice_file": "VOICE_MAIN_048_504_01060",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 24,
		"localized_name": "ララ",
		"romanized_name": "Lara",
		"model_path_hash": "4015600840793749786",
		"text": "話を付けてきますわ。すぐに戻ります",
		"voice_file": "VOICE_MAIN_005_504_01061",
		"still_path_hash": "803162819272915998",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 25,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "社長殿！？",
		"voice_file": "VOICE_MAIN_181_504_01062",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 26,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "なにする気かしら……",
		"voice_file": "VOICE_MAIN_004_504_01063",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 27,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "さあ……？",
		"voice_file": "VOICE_MAIN_048_504_01064",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	}
]