[
	{
		"id": 0,
		"localized_name": "ヤドヴィガ",
		"romanized_name": "Jadwiga",
		"model_path_hash": "2111970354351478659",
		"text": "胞子の流れを探知。さらに西の方角",
		"voice_file": "",
		"still_path_hash": "6170794110252514656",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "ありがとう。さあ、急ぐわよ！",
		"voice_file": "",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "イェルカ",
		"romanized_name": "Jelka",
		"model_path_hash": "7989768780593008340",
		"text": "待ちな！　なんだ、この強烈な「気」は……",
		"voice_file": "",
		"still_path_hash": "8715905000688515801",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "ヤドヴィガ",
		"romanized_name": "Jadwiga",
		"model_path_hash": "2111970354351478659",
		"text": "……！　胞子量の減少を確認。\n誰かが、魔物を倒している？",
		"voice_file": "",
		"still_path_hash": "6170794110252514656",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "イヤ……これは……この気配は……！",
		"voice_file": "",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "！！！",
		"voice_file": "",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "うぬら、我に胞子を浴びせるとは……",
		"voice_file": "",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "このキノコども、我を支配できるとでも思ったか！\n愚か者めが！！",
		"voice_file": "",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "イェルカ",
		"romanized_name": "Jelka",
		"model_path_hash": "7989768780593008340",
		"text": "ゼロ姉……！！",
		"voice_file": "",
		"still_path_hash": "8715905000688515801",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "シトリン",
		"romanized_name": "Citrine",
		"model_path_hash": "6017129171503572683",
		"text": "嘘だろ……キノコ相手にここまでやる？",
		"voice_file": "",
		"still_path_hash": "924100309011770274",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "ゼロ、なにしに来たのよ！",
		"voice_file": "",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "決まっておろう。ヤドヴィガ、キューン、\nうぬらを連れ戻しに来たのじゃ",
		"voice_file": "",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "あんたたちじゃ凶暴すぎるのよ。\n二人の面倒は私が見る。だから、帰ってもらうわ！",
		"voice_file": "",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "ほう？　皆がそう言っておると？",
		"voice_file": "",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "ええ、そうよ。当たり前じゃない！",
		"voice_file": "",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 15,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "ヤドヴィガ。パルメ族の使命を忘れたというのか？",
		"voice_file": "",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 16,
		"localized_name": "ヤドヴィガ",
		"romanized_name": "Jadwiga",
		"model_path_hash": "2111970354351478659",
		"text": "……否",
		"voice_file": "",
		"still_path_hash": "6170794110252514656",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 17,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "キューン！！！",
		"voice_file": "",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 18,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "ひっ……！",
		"voice_file": "",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 19,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "どうなんじゃ？\nヴァレリアが言っていることは、本当かのう？",
		"voice_file": "",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 20,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "私は……わた、し……は……ここ、に……",
		"voice_file": "",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 21,
		"localized_name": "ヤドヴィガ",
		"romanized_name": "Jadwiga",
		"model_path_hash": "2111970354351478659",
		"text": "やめて",
		"voice_file": "",
		"still_path_hash": "6170794110252514656",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 22,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "何様のつもりじゃ？　ヤドヴィガ",
		"voice_file": "",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 23,
		"localized_name": "ヤドヴィガ",
		"romanized_name": "Jadwiga",
		"model_path_hash": "2111970354351478659",
		"text": "キューン。正直な気持ちを、求める",
		"voice_file": "",
		"still_path_hash": "6170794110252514656",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 24,
		"localized_name": "ヤドヴィガ",
		"romanized_name": "Jadwiga",
		"model_path_hash": "2111970354351478659",
		"text": "大丈夫。私がいる",
		"voice_file": "",
		"still_path_hash": "6170794110252514656",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 25,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "0",
		"text": "…………",
		"voice_file": "",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 26,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "ここに、いたい……ここにいたいよおっ！",
		"voice_file": "",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 27,
		"localized_name": "ヤドヴィガ",
		"romanized_name": "Jadwiga",
		"model_path_hash": "2111970354351478659",
		"text": "……承知。ならば",
		"voice_file": "",
		"still_path_hash": "6170794110252514656",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 28,
		"localized_name": "ヤドヴィガ",
		"romanized_name": "Jadwiga",
		"model_path_hash": "2111970354351478659",
		"text": "キューンの笑顔を、私は守る。\n私も、ここに残る！",
		"voice_file": "",
		"still_path_hash": "6170794110252514656",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 29,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "抜かしおる……！！",
		"voice_file": "",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 30,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "二人とも、よく言ったわ！",
		"voice_file": "",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 31,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "ヴァレリアああああ！　皆を誑かしおって！\nお仕置きじゃ！",
		"voice_file": "",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 32,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "くっ……！　\nやっぱり、力が違いすぎる……！",
		"voice_file": "",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 33,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "ぐっ……！",
		"voice_file": "",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 34,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "……やめて",
		"voice_file": "",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 35,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "はあああ！！",
		"voice_file": "",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 36,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "があっ！！",
		"voice_file": "",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 37,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "ヴァレリア姉ちゃんを傷つけないで！！",
		"voice_file": "",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 38,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "ぬっ！！",
		"voice_file": "",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 39,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "はあ、はあ……私だって……",
		"voice_file": "",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 40,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "守られてばかりじゃない……みんなを、守るんだ！",
		"voice_file": "",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 41,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "キューン……",
		"voice_file": "",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 42,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "私……分かったんだ。\n誰かを守りたいって思ったとき、力が湧いてくるの",
		"voice_file": "",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 43,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "だってきっと、それが私の存在意義だから！",
		"voice_file": "",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 44,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "面白い！　うぬのその覚悟……しかと見せてみよ！",
		"voice_file": "",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 45,
		"localized_name": "ヤドヴィガ",
		"romanized_name": "Jadwiga",
		"model_path_hash": "2111970354351478659",
		"text": "キューン、右へ回避！　次は上から！",
		"voice_file": "",
		"still_path_hash": "6170794110252514656",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 46,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "うんっ！",
		"voice_file": "",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 47,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "ふははは！　良いぞ、良いぞ！　\nならば、こちらも少し本気でいくぞ！！",
		"voice_file": "",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 48,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "「九偉人」の２番目。戦うことが大好き。\n兄のヘルトと共に、世界を見て回っている途中",
		"voice_file": "",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	}
]