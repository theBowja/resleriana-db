	},
	{
		"id": 3,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "0",
		"text": "（みんなを楽しませたいという夢）",
		"voice_file": "VOICE_MAIN_048_504_00003",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "0",
		"text": "（世界一のアイドルになるという夢）",
		"voice_file": "VOICE_MAIN_004_504_00004",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "0",
		"text": "（新しい自分になるという夢）",
		"voice_file": "VOICE_MAIN_181_504_00005",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "0",
		"text": "（色とりどりの光が輝くステージで）",
		"voice_file": "VOICE_MAIN_048_504_00006",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "0",
		"text": "（私たちアイドルは、夢を見て）",
		"voice_file": "VOICE_MAIN_004_504_00007",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "0",
		"text": "（観客のみんなに夢を見せる）",
		"voice_file": "VOICE_MAIN_181_504_00008",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "609796561237155831",
		"text": "頑張ってね、みんな！",
		"voice_file": "VOICE_MAIN_001_504_00009",
		"still_path_hash": "6580594669171159823",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "ララ",
		"romanized_name": "Lara",
		"model_path_hash": "4015600840793749786",
		"text": "あなたたちの歌と踊りで、\n観客を沸かせてみせなさい！",
		"voice_file": "VOICE_MAIN_005_504_00010",
		"still_path_hash": "803162819272915998",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "では、参ろうか！　一世一代の大勝負に！",
		"voice_file": "VOICE_MAIN_181_504_00011",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "いつも通りやるだけよ。\nだって、私はいつも完璧なんだから",
		"voice_file": "VOICE_MAIN_004_504_00012",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "目いっぱい盛り上げていこー！　おー！",
		"voice_file": "VOICE_MAIN_048_504_00013",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
