[
	{
		"id": 0,
		"localized_name": "クリセルダ",
		"romanized_name": "Criselda",
		"model_path_hash": "2319149981238984606",
		"text": "アンチュ。これも食べるといいわ",
		"voice_file": "",
		"still_path_hash": "2415369427152481317",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "アンチュ",
		"romanized_name": "Antje",
		"model_path_hash": "4505991537255215219",
		"text": "う、うん",
		"voice_file": "",
		"still_path_hash": "3623196163129163432",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "イェーロ",
		"romanized_name": "YELLO",
		"model_path_hash": "0",
		"text": "アンチュ　ソノ野菜モ　健康ノタメニ　必要ナノヨ",
		"voice_file": "",
		"still_path_hash": "3623196163129163432",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "アンチュ",
		"romanized_name": "Antje",
		"model_path_hash": "4505991537255215219",
		"text": "わ、分かってる……わよ……",
		"voice_file": "",
		"still_path_hash": "3623196163129163432",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "クリセルダ",
		"romanized_name": "Criselda",
		"model_path_hash": "2319149981238984606",
		"text": "ふふ。全部食べたら、一緒にいい場所へ行きましょう。\n素敵なお店を見つけたのよ",
		"voice_file": "",
		"still_path_hash": "2415369427152481317",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "アンチュ",
		"romanized_name": "Antje",
		"model_path_hash": "4505991537255215219",
		"text": "お店……？",
		"voice_file": "",
		"still_path_hash": "3623196163129163432",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "クリセルダ",
		"romanized_name": "Criselda",
		"model_path_hash": "2319149981238984606",
		"text": "ええ。アンチュは気に入ると思うの",
		"voice_file": "",
		"still_path_hash": "2415369427152481317",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "アンチュ",
		"romanized_name": "Antje",
		"model_path_hash": "4505991537255215219",
		"text": "え、ええと……私、これから素材を探しに",
		"voice_file": "",
		"still_path_hash": "3623196163129163432",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "クリセルダ",
		"romanized_name": "Criselda",
		"model_path_hash": "2319149981238984606",
		"text": "素材？　どこまで行くの？　私も一緒に行こうかしら。\nアンチュにぴったりとくっついてね",
		"voice_file": "",
		"still_path_hash": "2415369427152481317",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "アンチュ",
		"romanized_name": "Antje",
		"model_path_hash": "4505991537255215219",
		"text": "え、えっと、その……クリセルダには内緒……っ！",
		"voice_file": "",
		"still_path_hash": "3623196163129163432",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "クリセルダ",
		"romanized_name": "Criselda",
		"model_path_hash": "2319149981238984606",
		"text": "私……何か悪いことをしたかしら？",
		"voice_file": "",
		"still_path_hash": "2415369427152481317",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "ララ",
		"romanized_name": "Lara",
		"model_path_hash": "0",
		"text": "（あらあら、呆然としてしまって）",
		"voice_file": "",
		"still_path_hash": "803162819272915998",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "ララ",
		"romanized_name": "Lara",
		"model_path_hash": "0",
		"text": "（アンチュの初めての反抗ですから、\n　無理もありませんわね）",
		"voice_file": "",
		"still_path_hash": "803162819272915998",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "ララ",
		"romanized_name": "Lara",
		"model_path_hash": "0",
		"text": "（それにしても、あの子は何を……？\n　後で、様子を見に行ってみましょうか）",
		"voice_file": "",
		"still_path_hash": "803162819272915998",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "クリセルダ",
		"romanized_name": "Criselda",
		"model_path_hash": "2319149981238984606",
		"text": "テス・ハイツマン。相変わらずかわいいわね",
		"voice_file": "",
		"still_path_hash": "2415369427152481317",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 15,
		"localized_name": "テス",
		"romanized_name": "Tess",
		"model_path_hash": "7713659418971358664",
		"text": "あっ、リゼ……じゃなかった、クリセルダ！\n元気だった～？",
		"voice_file": "",
		"still_path_hash": "1974319971304968741",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 16,
		"localized_name": "クリセルダ",
		"romanized_name": "Criselda",
		"model_path_hash": "2319149981238984606",
		"text": "ふふ、この通りよ",
		"voice_file": "",
		"still_path_hash": "2415369427152481317",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 17,
		"localized_name": "クリセルダ",
		"romanized_name": "Criselda",
		"model_path_hash": "2319149981238984606",
		"text": "ねぇ、折り入って頼みがあるの。あなたにとっても\nいい話だと思うのだけど……",
		"voice_file": "",
		"still_path_hash": "2415369427152481317",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 18,
		"localized_name": "テス",
		"romanized_name": "Tess",
		"model_path_hash": "7713659418971358664",
		"text": "へぇ、それは面白そう！　それならさ……",
		"voice_file": "",
		"still_path_hash": "1974319971304968741",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 19,
		"localized_name": "クリセルダ",
		"romanized_name": "Criselda",
		"model_path_hash": "2319149981238984606",
		"text": "ふふ、それは素敵ね。では早速……",
		"voice_file": "",
		"still_path_hash": "2415369427152481317",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 20,
		"localized_name": "ララ",
		"romanized_name": "Lara",
		"model_path_hash": "4015600840793749786",
		"text": "あら、今度は何を企んでいるのかしら？",
		"voice_file": "",
		"still_path_hash": "803162819272915998",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 21,
		"localized_name": "テス・ハイツマン",
		"romanized_name": "Tess Heitzmann",
		"model_path_hash": "0",
		"text": "兎耳の髪飾りが特徴的な、陽気で賑やかな女性。\n星誕祭の出来事をきっかけにクリセルダと親しくなった",
		"voice_file": "",
		"still_path_hash": "1974319971304968741",
		"speech_balloon_type_id": 780292254
	}
]