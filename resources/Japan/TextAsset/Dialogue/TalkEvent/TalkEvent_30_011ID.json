[
	{
		"id": 0,
		"localized_name": "ジェロン",
		"romanized_name": "Geron",
		"model_path_hash": "9151749121035711876",
		"text": "う、ぐうっ……重い、一撃だな……",
		"voice_file": "VOICE_MAIN_003_036_00411",
		"still_path_hash": "8725176872512870759",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "ティム",
		"romanized_name": "Tim",
		"model_path_hash": "9091556145679123684",
		"text": "や、やめろ！！",
		"voice_file": "VOICE_MAIN_604_036_00412",
		"still_path_hash": "6387934691877097610",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "ん？",
		"voice_file": "VOICE_MAIN_227_036_00413",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "ジェロン",
		"romanized_name": "Geron",
		"model_path_hash": "9151749121035711876",
		"text": "ティム……！",
		"voice_file": "VOICE_MAIN_003_036_00414",
		"still_path_hash": "8725176872512870759",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "ティム",
		"romanized_name": "Tim",
		"model_path_hash": "9091556145679123684",
		"text": "兄さんに、手を出すな！！",
		"voice_file": "VOICE_MAIN_604_036_00415",
		"still_path_hash": "6387934691877097610",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "ティムくん、危ないです……！",
		"voice_file": "VOICE_MAIN_001_036_00416",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "ティム",
		"romanized_name": "Tim",
		"model_path_hash": "9091556145679123684",
		"text": "ここ、今度は、僕が兄さんを守るんだ……！",
		"voice_file": "VOICE_MAIN_604_036_00417",
		"still_path_hash": "6387934691877097610",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "恐怖に震えながらも、必死で兄をかばう、か……\nいい心がけだな、弟のかがみってやつだ",
		"voice_file": "VOICE_MAIN_227_036_00418",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "兄者？",
		"voice_file": "VOICE_MAIN_228_036_00419",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "気が変わった。ゼロ、戦闘は中止だ",
		"voice_file": "VOICE_MAIN_227_036_00420",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "え、ええ……？",
		"voice_file": "VOICE_MAIN_002_036_00421",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "なぜじゃ！　我は暴れ足りぬぞ！　足～り～ぬ～！！",
		"voice_file": "VOICE_MAIN_228_036_00422",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "まあ落ち着け。俺に考えがある。せっかく楽しみを\n味わうなら、一番美味しく食べたいだろう？",
		"voice_file": "VOICE_MAIN_227_036_00423",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "ほう。何か思いついたんじゃな？\n兄者は昔っから頭がいいからのお",
		"voice_file": "VOICE_MAIN_228_036_00424",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "な、何が起こってるの……？",
		"voice_file": "VOICE_MAIN_150_036_00425",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 15,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "俺は寛大だからな。ティムくんの兄弟愛に免じて\n一度だけお前たち自身で物事を決める機会をくれてやる",
		"voice_file": "VOICE_MAIN_227_036_00426",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 16,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "腑抜けた妹たちに代わり、お前ら人類の手で\nクリセルダたち不穏分子を「管理」しろ",
		"voice_file": "VOICE_MAIN_227_036_00427",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 17,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "そ、そんなっ……！",
		"voice_file": "VOICE_MAIN_001_036_00428",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 18,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "期限は１週間だ。それまでに「管理」してなかったら\n今度こそ俺たちが手を下す",
		"voice_file": "VOICE_MAIN_227_036_00429",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 19,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "ほら帰るぞ、ゼロ、キューン",
		"voice_file": "VOICE_MAIN_227_036_00430",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 20,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "う、うん……",
		"voice_file": "VOICE_MAIN_200_036_00431",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 21,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "……１週間は助かった、のか……",
		"voice_file": "VOICE_MAIN_150_036_00432",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 22,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "あっ、とと……",
		"voice_file": "VOICE_MAIN_150_036_00433",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 23,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "大丈夫？　アルビーナ、すっごい汗よ？",
		"voice_file": "VOICE_MAIN_002_036_00434",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 24,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "な、なんとか……暗黒の氷海のあいつらに比べりゃ、\nまだ言葉が通じる相手だもん。大丈夫なはず……",
		"voice_file": "VOICE_MAIN_150_036_00435",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 25,
		"localized_name": "シトリン",
		"romanized_name": "Citrine",
		"model_path_hash": "6017129171503572683",
		"text": "……言葉が通じる相手なんかじゃないんだよ",
		"voice_file": "VOICE_MAIN_154_036_00436",
		"still_path_hash": "924100309011770274",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 26,
		"localized_name": "シトリン",
		"romanized_name": "Citrine",
		"model_path_hash": "6017129171503572683",
		"text": "僕が言うのもなんだけど、あの通り\nヘルトは昔から超が付く気分屋なんだよ",
		"voice_file": "VOICE_MAIN_154_036_00437",
		"still_path_hash": "924100309011770274",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 27,
		"localized_name": "シトリン",
		"romanized_name": "Citrine",
		"model_path_hash": "6017129171503572683",
		"text": "もう生き物というか、異常気象の領域だよ。\nその荒々しさと読めなさっていう意味でね",
		"voice_file": "VOICE_MAIN_154_036_00438",
		"still_path_hash": "924100309011770274",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 28,
		"localized_name": "シトリン",
		"romanized_name": "Citrine",
		"model_path_hash": "6017129171503572683",
		"text": "僕たち兄弟は振り回されっぱなしだし、\nゼロも血の気が多くて話し合いには応じない",
		"voice_file": "VOICE_MAIN_154_036_00439",
		"still_path_hash": "924100309011770274",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 29,
		"localized_name": "イェルカ",
		"romanized_name": "Jelka",
		"model_path_hash": "7989768780593008340",
		"text": "昔から戦いが大好きで、自分が九偉人で最強だと\n思っているからなぁ、ゼロ姉は",
		"voice_file": "VOICE_MAIN_153_036_00440",
		"still_path_hash": "8715905000688515801",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 30,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "ゼロってのは０番目ってこと……じゃないのよね？\nそんな口ぶりしてたわ",
		"voice_file": "VOICE_MAIN_150_036_00441",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 31,
		"localized_name": "シトリン",
		"romanized_name": "Citrine",
		"model_path_hash": "6017129171503572683",
		"text": "本当は２番目のホムンクルスなんだけど\n１番のヘルトより強いって自称してるのさ",
		"voice_file": "VOICE_MAIN_154_036_00442",
		"still_path_hash": "924100309011770274",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 32,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "確かに、そう自称するのも頷ける強さだった……",
		"voice_file": "VOICE_MAIN_150_036_00443",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 33,
		"localized_name": "シトリン",
		"romanized_name": "Citrine",
		"model_path_hash": "6017129171503572683",
		"text": "そんなわけで、話が通じるとは思わないほうがいい。\nあっち側からの一方通行で、大変なんだよ……",
		"voice_file": "VOICE_MAIN_154_036_00444",
		"still_path_hash": "924100309011770274",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 34,
		"localized_name": "ジョゼ",
		"romanized_name": "José",
		"model_path_hash": "0",
		"text": "おいおい、なんなんだあいつらは……\nとんでもない奴らが来ちまったな……",
		"voice_file": "VOICE_MAIN_223_036_00445",
		"still_path_hash": "1488533364831425921",
		"speech_balloon_type_id": 780292254
	}
]