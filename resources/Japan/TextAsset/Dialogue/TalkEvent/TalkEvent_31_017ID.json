[
	{
		"id": 0,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "ふっ……久しぶりに、暴れられた……",
		"voice_file": "VOICE_MAIN_228_037_00546",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "全力でやっても死なない相手……満足、じゃ……",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "3986021654722714881",
		"text": "なんか満足して倒れたんすけど……",
		"voice_file": "VOICE_MAIN_150_037_00547",
		"still_path_hash": "4227931788932007159",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "イェルカ",
		"romanized_name": "Jelka",
		"model_path_hash": "7989768780593008340",
		"text": "ほんと、いくつになっても子どもだねえ",
		"voice_file": "VOICE_MAIN_153_037_00548",
		"still_path_hash": "8715905000688515801",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "まったくだ。いくら力が強くても頭が幼い",
		"voice_file": "VOICE_MAIN_227_037_00549",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "そこを付けこまれるから格下相手に不覚を取る",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "3986021654722714881",
		"text": "妹に対して、その言い草はないんじゃないの？",
		"voice_file": "VOICE_MAIN_150_037_00550",
		"still_path_hash": "4227931788932007159",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "いや？　その点俺は、力も頭脳も完璧な英雄だ",
		"voice_file": "VOICE_MAIN_227_037_00551",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "万が一にも不覚はない",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "シトリン",
		"romanized_name": "Citrine",
		"model_path_hash": "6017129171503572683",
		"text": "そういうこと口にする輩ほど",
		"voice_file": "VOICE_MAIN_154_037_00552",
		"still_path_hash": "924100309011770274",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "足を掬われるってのが相場だけどね",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "その高ーく伸びた鼻っ柱",
		"voice_file": "VOICE_MAIN_002_037_00553",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "ボキボキに折ってやるんだから！",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "みんな、あと一息だよ！",
		"voice_file": "VOICE_MAIN_001_037_00554",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "頑張ろう！！",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 15,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "あと一息、だと？",
		"voice_file": "VOICE_MAIN_227_037_00555",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 16,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "一息でこのヘルトの炎",
		"voice_file": "VOICE_MAIN_227_037_00556",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 17,
		"localized_name": "",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "吹き消せるものならば吹き消してみるがいい！！",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 18,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "ひっ……兄貴がこんなに怒ったの、初めて……！",
		"voice_file": "VOICE_MAIN_200_037_00557",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 19,
		"localized_name": "ヤドヴィガ",
		"romanized_name": "Jadwiga",
		"model_path_hash": "2111970354351478659",
		"text": "虎の尾を踏んでしまった……",
		"voice_file": "VOICE_MAIN_199_037_00558",
		"still_path_hash": "6170794110252514656",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 20,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "数頼みの戦略は、俺には通用しないぞ！",
		"voice_file": "VOICE_MAIN_227_037_00559",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 21,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "3986021654722714881",
		"text": "ッ！？　ベップ、ヤンネさん！",
		"voice_file": "VOICE_MAIN_150_037_00560",
		"still_path_hash": "4227931788932007159",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 22,
		"localized_name": "ヤンネ",
		"romanized_name": "Janne",
		"model_path_hash": "1819147851487138677",
		"text": "くうっ……！",
		"voice_file": "VOICE_MAIN_152_037_00561",
		"still_path_hash": "6181229795949782132",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 23,
		"localized_name": "ベップ",
		"romanized_name": "Bepp",
		"model_path_hash": "3101416597918110218",
		"text": "ダメ……逃げて、姉様！",
		"voice_file": "VOICE_MAIN_151_037_00562",
		"still_path_hash": "5045460652135134961",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 24,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "でやあぁっ！！",
		"voice_file": "VOICE_MAIN_002_037_00563",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 25,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "ッ！？　す、素手で……！",
		"voice_file": "VOICE_MAIN_002_037_00564",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 26,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "軽い",
		"voice_file": "VOICE_MAIN_227_037_00565",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 27,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "ヴァレリア！！",
		"voice_file": "VOICE_MAIN_001_037_00566",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 28,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "3986021654722714881",
		"text": "アタシだって、隙さえあれば……",
		"voice_file": "VOICE_MAIN_150_037_00567",
		"still_path_hash": "4227931788932007159",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 29,
		"localized_name": "エルス",
		"romanized_name": "Els",
		"model_path_hash": "5033911810886101706",
		"text": "隙を作ればいいんだな？",
		"voice_file": "VOICE_MAIN_222_037_00568",
		"still_path_hash": "532943395044460292",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 30,
		"localized_name": "メーヴェ",
		"romanized_name": "Mowen",
		"model_path_hash": "8282561094361780418",
		"text": "隙なら作るよっ！",
		"voice_file": "VOICE_MAIN_235_037_00569",
		"still_path_hash": "7917604627487944706",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 31,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "雷？　いや、剣撃か？",
		"voice_file": "VOICE_MAIN_227_037_00570",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 32,
		"localized_name": "",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "この領域に達するとはなかなか見どころがあるな",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 33,
		"localized_name": "メーヴェ",
		"romanized_name": "Mowen",
		"model_path_hash": "8282561094361780418",
		"text": "それはどうも。これは家族愛の為せる業よ！",
		"voice_file": "VOICE_MAIN_235_037_00571",
		"still_path_hash": "7917604627487944706",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 34,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "ふん……偽りの血縁で愛を語るか",
		"voice_file": "VOICE_MAIN_227_037_00572",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 35,
		"localized_name": "エルス",
		"romanized_name": "Els",
		"model_path_hash": "5033911810886101706",
		"text": "次はこっちだ！",
		"voice_file": "VOICE_MAIN_222_037_00573",
		"still_path_hash": "532943395044460292",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 36,
		"localized_name": "エルス",
		"romanized_name": "Els",
		"model_path_hash": "5033911810886101706",
		"text": "私の部下を石にしたこと、許しはしない！",
		"voice_file": "VOICE_MAIN_222_037_00573_00",
		"still_path_hash": "532943395044460292",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 37,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "お前も人間のわりになかなかやるようだが",
		"voice_file": "VOICE_MAIN_227_037_00574",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 38,
		"localized_name": "",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "俺には届かない",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 39,
		"localized_name": "エルス",
		"romanized_name": "Els",
		"model_path_hash": "5033911810886101706",
		"text": "今だ、アルビーナ！",
		"voice_file": "VOICE_MAIN_222_037_00575",
		"still_path_hash": "532943395044460292",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 40,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "3986021654722714881",
		"text": "恩に着るっす！！",
		"voice_file": "VOICE_MAIN_150_037_00576",
		"still_path_hash": "4227931788932007159",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 41,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "3986021654722714881",
		"text": "いっけえええぇっ！！！",
		"voice_file": "VOICE_MAIN_150_037_00577",
		"still_path_hash": "4227931788932007159",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 42,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "フン……何をするかと思えば。俺への献上品か？",
		"voice_file": "VOICE_MAIN_227_037_00578",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 43,
		"localized_name": "",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "爆弾ならともかく、投石など何度やっても同じだ",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 44,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "3986021654722714881",
		"text": "……触れたな？",
		"voice_file": "VOICE_MAIN_150_037_00579",
		"still_path_hash": "4227931788932007159",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 45,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "なっ―――",
		"voice_file": "VOICE_MAIN_227_037_00580",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 46,
		"localized_name": "クレオ",
		"romanized_name": "Cleo",
		"model_path_hash": "1405587059148187981",
		"text": "これが！！",
		"voice_file": "VOICE_MAIN_234_037_00581",
		"still_path_hash": "6779436863461642750",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 47,
		"localized_name": "",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "光星隊の力！！！！",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 48,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "ぐあああぁぁっ！！？",
		"voice_file": "VOICE_MAIN_227_037_00582",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 49,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "い、いったい、何が起こった……？",
		"voice_file": "VOICE_MAIN_227_037_00583",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 50,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "3986021654722714881",
		"text": "本当、無茶もいいところだよ。アタシが創り出した",
		"voice_file": "VOICE_MAIN_150_037_00584",
		"still_path_hash": "4227931788932007159",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 51,
		"localized_name": "",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "亜空間に待ち伏せして、気を練り続けるなんて",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 52,
		"localized_name": "クレオ",
		"romanized_name": "Cleo",
		"model_path_hash": "1405587059148187981",
		"text": "でも、できたから、結果よし！",
		"voice_file": "VOICE_MAIN_234_037_00585",
		"still_path_hash": "6779436863461642750",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 53,
		"localized_name": "クレオ",
		"romanized_name": "Cleo",
		"model_path_hash": "1405587059148187981",
		"text": "みんな……光星隊の借り、返したよ！",
		"voice_file": "VOICE_MAIN_234_037_00586",
		"still_path_hash": "6779436863461642750",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 54,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "亜空間を創り出す……もしや亜空の道……",
		"voice_file": "VOICE_MAIN_227_037_00587",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 55,
		"localized_name": "",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "ガイストコアを独学で調合したというのか！？",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 56,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "3986021654722714881",
		"text": "なにそれ？　知らないんすけど",
		"voice_file": "VOICE_MAIN_150_037_00588",
		"still_path_hash": "4227931788932007159",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 57,
		"localized_name": "",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "これはアタシの集大成",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 58,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "3986021654722714881",
		"text": "師匠から教えてもらったことや",
		"voice_file": "VOICE_MAIN_150_037_00589",
		"still_path_hash": "4227931788932007159",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 59,
		"localized_name": "",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "レスナやヴァレリアと過ごして学んだこと",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 60,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "3986021654722714881",
		"text": "自分の知識と経験を総動員してたどり着いた答え！",
		"voice_file": "VOICE_MAIN_150_037_00590",
		"still_path_hash": "4227931788932007159",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 61,
		"localized_name": "",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "敵を弱くし、こちらを強くする亜空間！！",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 62,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "そ、そのように都合のいい空間など……",
		"voice_file": "VOICE_MAIN_227_037_00591",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 63,
		"localized_name": "",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "存在して、よいわけが！",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 64,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "3986021654722714881",
		"text": "あるのよね、これが",
		"voice_file": "VOICE_MAIN_150_037_00592",
		"still_path_hash": "4227931788932007159",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 65,
		"localized_name": "",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "もちろん、探すのは大変だったけど……",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 66,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "わぁ……なんだか不思議な世界",
		"voice_file": "VOICE_MAIN_001_037_00593",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 67,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "7061794453237574237",
		"text": "ここがアルビ空間か～",
		"voice_file": "VOICE_MAIN_048_037_00594",
		"still_path_hash": "7010833269667927555",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 68,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "3986021654722714881",
		"text": "団体の皆様、ようこそいらっしゃいました",
		"voice_file": "VOICE_MAIN_150_037_00595",
		"still_path_hash": "4227931788932007159",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 69,
		"localized_name": "",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "引率はアタシ……",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 70,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "3986021654722714881",
		"text": "錬金術士にして星の案内人！",
		"voice_file": "VOICE_MAIN_150_037_00596",
		"still_path_hash": "4227931788932007159",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 71,
		"localized_name": "",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "アルビーナ・ジムロックが務めさせていただきます！",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 72,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "このような形で不覚を取るとは……っ！",
		"voice_file": "VOICE_MAIN_227_037_00597",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 73,
		"localized_name": "シトリン",
		"romanized_name": "Citrine",
		"model_path_hash": "6017129171503572683",
		"text": "だから言ったのに、足を掬われるって",
		"voice_file": "VOICE_MAIN_154_037_00598",
		"still_path_hash": "924100309011770274",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 74,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "3986021654722714881",
		"text": "慢心してくださってありがとうございます",
		"voice_file": "VOICE_MAIN_150_037_00599",
		"still_path_hash": "4227931788932007159",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 75,
		"localized_name": "",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "あんな石ころよけられるのに、受け止めてくださって",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 76,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "3986021654722714881",
		"text": "肉体、頭脳共に最強の存在、その身を滅ぼすのは",
		"voice_file": "VOICE_MAIN_150_037_00600",
		"still_path_hash": "4227931788932007159",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 77,
		"localized_name": "",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "己の慢心よっ！",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 78,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "お、おのれええええぇぇッ！！！",
		"voice_file": "VOICE_MAIN_227_037_00601",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 79,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "英雄に勝てるなどと、思い上がるな！",
		"voice_file": "VOICE_MAIN_227_042_01509",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 80,
		"localized_name": "クレオ",
		"romanized_name": "Cleo",
		"model_path_hash": "1405587059148187981",
		"text": "はあああああああっ！！",
		"voice_file": "VOICE_MAIN_234_037_00581_b",
		"still_path_hash": "6779436863461642750",
		"speech_balloon_type_id": 780292254
	}
]