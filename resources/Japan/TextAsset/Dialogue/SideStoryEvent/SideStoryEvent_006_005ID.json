[
	{
		"id": 0,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "ふう……全部倒せたわね",
		"voice_file": "",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "イェルカ",
		"romanized_name": "Jelka",
		"model_path_hash": "7989768780593008340",
		"text": "やれやれ。これで胞子はなくなりそうかい？",
		"voice_file": "",
		"still_path_hash": "8715905000688515801",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "ヤドヴィガ",
		"romanized_name": "Jadwiga",
		"model_path_hash": "2111970354351478659",
		"text": "胞子濃度、低下中。状況は解決した模様",
		"voice_file": "",
		"still_path_hash": "6170794110252514656",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "よかった……みんな、助かる……かな",
		"voice_file": "",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "シトリン",
		"romanized_name": "Citrine",
		"model_path_hash": "6017129171503572683",
		"text": "安心してる場合？　レスナたちはともかく、ずっと\n胞子にさらされ続けた島の人たちが危ないんじゃない？",
		"voice_file": "",
		"still_path_hash": "924100309011770274",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "！！　町に急ぎましょう！",
		"voice_file": "",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "住民Ａ",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "うぅ……",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "住民Ｂ",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "はぁ、はぁ……",
		"voice_file": "",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "……酷い有様ね。\nみんな、胞子のせいで……",
		"voice_file": "",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "か……身体からキノコが生えてる人が……！　\nこれ、どうしたら……",
		"voice_file": "",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "シトリン",
		"romanized_name": "Citrine",
		"model_path_hash": "6017129171503572683",
		"text": "まったく……言わんこっちゃない。\nで、状況はどうなの、ヤドヴィガ？",
		"voice_file": "",
		"still_path_hash": "924100309011770274",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "ヤドヴィガ",
		"romanized_name": "Jadwiga",
		"model_path_hash": "2111970354351478659",
		"text": "状況、分析。\n住民の症状は胞子の毒素によるもの",
		"voice_file": "",
		"still_path_hash": "6170794110252514656",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "なら、毒素を抜く薬を作らなきゃ！\nレスナに相談――って、レスナもやられてるんだった",
		"voice_file": "",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "ヤドヴィガ",
		"romanized_name": "Jadwiga",
		"model_path_hash": "2111970354351478659",
		"text": "薬のレシピの提案あり。\n原因となった胞子を採取、分析する",
		"voice_file": "",
		"still_path_hash": "6170794110252514656",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "薬、作れるってことね！",
		"voice_file": "",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 15,
		"localized_name": "ヤドヴィガ",
		"romanized_name": "Jadwiga",
		"model_path_hash": "2111970354351478659",
		"text": "ヴァレリア姉上以降の九偉人には、\n調合機能が組み込まれている",
		"voice_file": "",
		"still_path_hash": "6170794110252514656",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 16,
		"localized_name": "ヤドヴィガ",
		"romanized_name": "Jadwiga",
		"model_path_hash": "2111970354351478659",
		"text": "ただ、姉上は戦闘機能重視。\n私とキューンは、錬金術のほうに長けている",
		"voice_file": "",
		"still_path_hash": "6170794110252514656",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 17,
		"localized_name": "ヤドヴィガ",
		"romanized_name": "Jadwiga",
		"model_path_hash": "2111970354351478659",
		"text": "０から１を生み出す創造性は、\n人間の錬金術士には及ばないものの――",
		"voice_file": "",
		"still_path_hash": "6170794110252514656",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 18,
		"localized_name": "ヤドヴィガ",
		"romanized_name": "Jadwiga",
		"model_path_hash": "2111970354351478659",
		"text": "今回のような、原因が明確な問題への対処は得意",
		"voice_file": "",
		"still_path_hash": "6170794110252514656",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 19,
		"localized_name": "イェルカ",
		"romanized_name": "Jelka",
		"model_path_hash": "7989768780593008340",
		"text": "上出来さね、お前さんに従おう。\nほら、みんな！　必要な素材を集めるよ！",
		"voice_file": "",
		"still_path_hash": "8715905000688515801",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 20,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "ありがと。ヤドヴィガがいて助かったわ",
		"voice_file": "",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 21,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "よかった……みんな治るんだね……！",
		"voice_file": "",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 22,
		"localized_name": "ヤドヴィガ",
		"romanized_name": "Jadwiga",
		"model_path_hash": "2111970354351478659",
		"text": "……私は、遂行可能なことを遂行しているだけ",
		"voice_file": "",
		"still_path_hash": "6170794110252514656",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 23,
		"localized_name": "イェルカ",
		"romanized_name": "Jelka",
		"model_path_hash": "7989768780593008340",
		"text": "でも、悪くないだろ？　感謝されるってのは",
		"voice_file": "",
		"still_path_hash": "8715905000688515801",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 24,
		"localized_name": "ヤドヴィガ",
		"romanized_name": "Jadwiga",
		"model_path_hash": "2111970354351478659",
		"text": "……嬉しい。不思議な感覚",
		"voice_file": "",
		"still_path_hash": "6170794110252514656",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 25,
		"localized_name": "シトリン",
		"romanized_name": "Citrine",
		"model_path_hash": "6017129171503572683",
		"text": "じゃ、面倒ごとはさっさと片付けちゃおっか",
		"voice_file": "",
		"still_path_hash": "924100309011770274",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 26,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "ええ！　みんなで力を合わせて、\n町の人たちを元に戻す薬を作るわよ！",
		"voice_file": "",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	}
]