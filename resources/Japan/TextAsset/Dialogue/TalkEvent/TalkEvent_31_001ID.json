[
	{
		"id": 0,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "はぁっ！",
		"voice_file": "VOICE_MAIN_227_037_00000",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "くっ！",
		"voice_file": "VOICE_MAIN_002_037_00001",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "0",
		"text": "（果ての大陸への鍵となる「九偉人図」。\n　９枚のうち５枚を手に入れることができた）",
		"voice_file": "VOICE_MAIN_002_037_00002",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "0",
		"text": "（でもその途中、私の兄と姉にあたる九偉人\n　ヘルトとゼロが立ちはだかった）",
		"voice_file": "VOICE_MAIN_002_037_00003",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "どうした妹？　俺らに勝って２枚の「九偉人図」を\n手に入れるのではなかったのか？",
		"voice_file": "VOICE_MAIN_227_037_00004",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "イェルカ",
		"romanized_name": "Jelka",
		"model_path_hash": "7989768780593008340",
		"text": "もちろん手に入れるさね、\nヘル兄たちの強制的な「管理」を止めるためにも！",
		"voice_file": "VOICE_MAIN_153_037_00005",
		"still_path_hash": "8715905000688515801",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "0",
		"text": "（二人が決戦に指定してきたのはここ、\n　人の住めない無人島、雷鳴の島だった）",
		"voice_file": "VOICE_MAIN_002_037_00006",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "打ち込んでこいよ。\n石となった仲間が砕けてもいいのならな",
		"voice_file": "VOICE_MAIN_227_037_00007",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "レスナ……！　まったく、揺さぶってくれるわね",
		"voice_file": "VOICE_MAIN_002_037_00008",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "0",
		"text": "（でも、二人の罠にはまってレスナたちは\n　石化してしまった……）",
		"voice_file": "VOICE_MAIN_002_037_00009",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "イェルカ",
		"romanized_name": "Jelka",
		"model_path_hash": "7989768780593008340",
		"text": "大丈夫、ヴァレリア。今にハイディたちが\n石化を解く薬を持ってきてくれるよ",
		"voice_file": "VOICE_MAIN_153_037_00010",
		"still_path_hash": "8715905000688515801",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "ふん、減らず口を。\nお前たちが音を上げるのが先だろう？",
		"voice_file": "VOICE_MAIN_227_037_00011",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "従順になるまで徹底的に教育し\n兄弟の序列を叩き込んでやるぞ",
		"voice_file": "VOICE_MAIN_227_037_00012",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "力で従わせてくるお兄ちゃんなんて、\n誰も望んでないわよ！",
		"voice_file": "VOICE_MAIN_002_037_00013",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "イェルカ",
		"romanized_name": "Jelka",
		"model_path_hash": "7989768780593008340",
		"text": "石化能力を持つ危険な魔物を「管理」せず\nこの島に持ち込んでの私的利用……",
		"voice_file": "VOICE_MAIN_153_037_00014",
		"still_path_hash": "8715905000688515801",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 15,
		"localized_name": "イェルカ",
		"romanized_name": "Jelka",
		"model_path_hash": "7989768780593008340",
		"text": "たとえ兄といえども不届き千万さ！\nそうだろ？　シトリン！　言ってやりなシトリン！",
		"voice_file": "VOICE_MAIN_153_037_00015",
		"still_path_hash": "8715905000688515801",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 16,
		"localized_name": "シトリン",
		"romanized_name": "Citrine",
		"model_path_hash": "6017129171503572683",
		"text": "そ、そんなの知らないよ！\n僕のほうに注意を向けさせないでほしいな",
		"voice_file": "VOICE_MAIN_154_037_00016",
		"still_path_hash": "924100309011770274",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 17,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "シトリン、お前が俺に攻撃してきたことは\n忘れないぞ。言い訳は聞かないからな",
		"voice_file": "VOICE_MAIN_227_037_00017",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 18,
		"localized_name": "シトリン",
		"romanized_name": "Citrine",
		"model_path_hash": "6017129171503572683",
		"text": "はぁぁぁ、もう。イェルカ、恨むよ",
		"voice_file": "VOICE_MAIN_154_037_00018",
		"still_path_hash": "924100309011770274",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 19,
		"localized_name": "シトリン",
		"romanized_name": "Citrine",
		"model_path_hash": "6017129171503572683",
		"text": "逃げられないんだったら、\n後悔のない一撃、お見舞いしてやる！",
		"voice_file": "VOICE_MAIN_154_037_00019",
		"still_path_hash": "924100309011770274",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 20,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "ヴァレリア姉ちゃん！",
		"voice_file": "VOICE_MAIN_200_037_00020",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 21,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "キューンにヤドヴィガ！？\n待っててって言ったのに！",
		"voice_file": "VOICE_MAIN_002_037_00021",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 22,
		"localized_name": "ヤドヴィガ",
		"romanized_name": "Jadwiga",
		"model_path_hash": "2111970354351478659",
		"text": "私たちに兄上たちの相手は荷が重い……\nその判断は正しい……けれど",
		"voice_file": "VOICE_MAIN_199_037_00022",
		"still_path_hash": "6170794110252514656",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 23,
		"localized_name": "ヤドヴィガ",
		"romanized_name": "Jadwiga",
		"model_path_hash": "2111970354351478659",
		"text": "我が主の指示は不穏分子の「管理」。\n魔物の私的利用は本来の職務から逸脱しています",
		"voice_file": "VOICE_MAIN_199_037_00023",
		"still_path_hash": "6170794110252514656",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 24,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "相変わらずの真面目ぶりだ。\n頭にクソが付くほどのな",
		"voice_file": "VOICE_MAIN_227_037_00024",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 25,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "そんな汚い言葉、使っちゃ……ダメなんだから！",
		"voice_file": "VOICE_MAIN_200_037_00025",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 26,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "おいおい、１対５か。いや……\nこれで２対５、だな",
		"voice_file": "VOICE_MAIN_227_037_00026",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 27,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "かように面白き戦いから、我を仲間外れにするとは。\n兄者、意地悪じゃぞ！　我は抗議する！",
		"voice_file": "VOICE_MAIN_228_037_00027",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 28,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "お前なら勝手に戦の匂いを嗅ぎつけて来るだろう？\nしかし、こうなるといささか惜しいな",
		"voice_file": "VOICE_MAIN_227_037_00028",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 29,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "どうせならゴゥとリーベもいれば全員集合。\n九偉人内の力の差を手っ取り早く見せられたのだが",
		"voice_file": "VOICE_MAIN_227_037_00029",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 30,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "あの二人は聡い、一見せずとも一聞で理解しよう。\n長男と長女の強さというものを",
		"voice_file": "VOICE_MAIN_228_037_00030",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 31,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "……そうじゃ！　この後、倒れたヴァレリアたちを\n引きずって、ゴゥとリーベに見せに行こう！",
		"voice_file": "VOICE_MAIN_228_037_00031",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 32,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "ゼロ、見せに行くのはいいが、全員は面倒だ。\n一人でいいだろう",
		"voice_file": "VOICE_MAIN_227_037_00032",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 33,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "おおっ、効率ってやつじゃな！　\nまっこと兄者は頭が良い",
		"voice_file": "VOICE_MAIN_228_037_00033",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 34,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "まぁ、まずは全員倒してから考えればよいか。\nさぁさぁ祭りじゃ祭りじゃ、派手にいくぞ",
		"voice_file": "VOICE_MAIN_228_037_00034",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 35,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "舐めないで……私は絶対に負けない……",
		"voice_file": "VOICE_MAIN_002_037_00035",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 36,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "ヴァレリア、お願い。\n信じてる",
		"voice_file": "VOICE_MAIN_001_037_00036",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 37,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "レスナと、約束したから！！",
		"voice_file": "VOICE_MAIN_002_037_00037",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	}
]