[
	{
		"id": 0,
		"localized_name": "キースグリフ",
		"romanized_name": "Keithgrif",
		"model_path_hash": "703841452402553687",
		"text": "……ふん。やはり、これといった成果はないか。\n無駄足だったな",
		"voice_file": "",
		"still_path_hash": "8911695089895149925",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "キースグリフ",
		"romanized_name": "Keithgrif",
		"model_path_hash": "703841452402553687",
		"text": "…………？",
		"voice_file": "",
		"still_path_hash": "8911695089895149925",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "キースグリフ",
		"romanized_name": "Keithgrif",
		"model_path_hash": "703841452402553687",
		"text": "……なんだ、これは。\nまさか、上空から転移してきたのか",
		"voice_file": "",
		"still_path_hash": "8911695089895149925",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "キースグリフ",
		"romanized_name": "Keithgrif",
		"model_path_hash": "703841452402553687",
		"text": "小癪な真似を。やはり転移の類か",
		"voice_file": "",
		"still_path_hash": "8911695089895149925",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "キースグリフ",
		"romanized_name": "Keithgrif",
		"model_path_hash": "703841452402553687",
		"text": "しかし、空間が繋がっているというのであれば、\nこちらから向こうへ送り返すことも可能ということ",
		"voice_file": "",
		"still_path_hash": "8911695089895149925",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "キースグリフ",
		"romanized_name": "Keithgrif",
		"model_path_hash": "703841452402553687",
		"text": "……そこだ",
		"voice_file": "",
		"still_path_hash": "8911695089895149925",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "スール",
		"romanized_name": "Suelle",
		"model_path_hash": "3072540865312949120",
		"text": "どんどん送り込めー！\nユーディットさん、追加の準備できた？",
		"voice_file": "",
		"still_path_hash": "8906082768242880907",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "ユーディー",
		"romanized_name": "Judie",
		"model_path_hash": "2697025160672431728",
		"text": "ばっちり！　キースさん、どんな顔してるかな～",
		"voice_file": "",
		"still_path_hash": "2032894617718182411",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "スール",
		"romanized_name": "Suelle",
		"model_path_hash": "3072540865312949120",
		"text": "よーし、もっとたくさん送っちゃえ！　\nえいっ、えいっ――",
		"voice_file": "",
		"still_path_hash": "8906082768242880907",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "スール",
		"romanized_name": "Suelle",
		"model_path_hash": "3072540865312949120",
		"text": "……え？　何か向こうから送られてきた？",
		"voice_file": "",
		"still_path_hash": "8906082768242880907",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "ユーディー",
		"romanized_name": "Judie",
		"model_path_hash": "2697025160672431728",
		"text": "げ！　フラム！？",
		"voice_file": "",
		"still_path_hash": "2032894617718182411",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "プラフタ",
		"romanized_name": "Plachta",
		"model_path_hash": "894414068988709786",
		"text": "あなたたち、何を――",
		"voice_file": "",
		"still_path_hash": "8944192761651257696",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "ロジー",
		"romanized_name": "Logy",
		"model_path_hash": "3061836162665800468",
		"text": "おい……何があったんだ、これは……",
		"voice_file": "",
		"still_path_hash": "8747806484636614570",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "スール",
		"romanized_name": "Suelle",
		"model_path_hash": "3072540865312949120",
		"text": "……うぅ、やられた……",
		"voice_file": "",
		"still_path_hash": "8906082768242880907",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "ユーディー",
		"romanized_name": "Judie",
		"model_path_hash": "2697025160672431728",
		"text": "まさか、送り返してくるなんて……",
		"voice_file": "",
		"still_path_hash": "2032894617718182411",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 15,
		"localized_name": "プラフタ",
		"romanized_name": "Plachta",
		"model_path_hash": "894414068988709786",
		"text": "まったく、何かイタズラでもしていたのでしょう",
		"voice_file": "",
		"still_path_hash": "8944192761651257696",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 16,
		"localized_name": "ロジー",
		"romanized_name": "Logy",
		"model_path_hash": "3061836162665800468",
		"text": "はは……懲りたか？　\n次はほどほどにしとけよ",
		"voice_file": "",
		"still_path_hash": "8747806484636614570",
		"speech_balloon_type_id": 780292254
	}
]