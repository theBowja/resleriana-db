[
	{
		"id": 0,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "何が管理よ、そんなのただの支配じゃない……！",
		"voice_file": "VOICE_MAIN_002_036_00352",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "だったら問答無用、力ずくで言うことを聞かせるか？",
		"voice_file": "VOICE_MAIN_227_036_00353",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "分かりやすくて、その趣向望むところだが",
		"voice_file": "VOICE_MAIN_227_036_00354",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "うむ。てっきり襲ってきてくれるかと",
		"voice_file": "VOICE_MAIN_228_036_00355",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "レロレロ舌舐めずりしておったのじゃがな",
		"voice_file": "VOICE_MAIN_228_036_00356",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "お、お生憎様……そっちの手には乗らないって！",
		"voice_file": "VOICE_MAIN_150_036_00357",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "シトリン",
		"romanized_name": "Citrine",
		"model_path_hash": "6017129171503572683",
		"text": "アルビーナ、絶対、絶対刺激するなよ",
		"voice_file": "VOICE_MAIN_154_036_00358",
		"still_path_hash": "924100309011770274",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "らしくないわね、アンタ",
		"voice_file": "VOICE_MAIN_150_036_00359",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "シトリン",
		"romanized_name": "Citrine",
		"model_path_hash": "6017129171503572683",
		"text": "頭が混乱してるよ、そもそも……",
		"voice_file": "VOICE_MAIN_154_036_00360",
		"still_path_hash": "924100309011770274",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "シトリン",
		"romanized_name": "Citrine",
		"model_path_hash": "6017129171503572683",
		"text": "ヘルトがアウグストの言うことを素直に聞くなんて",
		"voice_file": "VOICE_MAIN_154_036_00361",
		"still_path_hash": "924100309011770274",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "俺とゼロが必要になるなど、いったい何ごとかと思えば……",
		"voice_file": "VOICE_MAIN_227_036_00362",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "今は、特に大きな災厄があるわけでもなし",
		"voice_file": "VOICE_MAIN_227_036_00363",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "こんなのは拍子抜けもいいところだろ",
		"voice_file": "",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "ならばさしあたって、",
		"voice_file": "VOICE_MAIN_227_036_00364",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "俺が面白く思える目標が欲しいんだ",
		"voice_file": "",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 15,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "せっかくの目覚めなのだからな",
		"voice_file": "VOICE_MAIN_227_036_00365",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 16,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "そちらの小娘の言葉を借りるなら……",
		"voice_file": "VOICE_MAIN_228_036_00366",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 17,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "あえてアウグストの手に乗るのも面白そうじゃろう？",
		"voice_file": "VOICE_MAIN_228_036_00367",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 18,
		"localized_name": "シトリン",
		"romanized_name": "Citrine",
		"model_path_hash": "6017129171503572683",
		"text": "くっ……気分屋め",
		"voice_file": "VOICE_MAIN_154_036_00368",
		"still_path_hash": "924100309011770274",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 19,
		"localized_name": "シトリン",
		"romanized_name": "Citrine",
		"model_path_hash": "6017129171503572683",
		"text": "ひょっとしたら、味方してくれる可能性もあったのに、",
		"voice_file": "VOICE_MAIN_154_036_00369",
		"still_path_hash": "924100309011770274",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 20,
		"localized_name": "シトリン",
		"romanized_name": "Citrine",
		"model_path_hash": "6017129171503572683",
		"text": "裏目か",
		"voice_file": "",
		"still_path_hash": "924100309011770274",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 21,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "暇つぶしで「管理」される身にもなってほしいっての……",
		"voice_file": "VOICE_MAIN_150_036_00370",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 22,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "これはアウグストさんや師匠にも伝えてますけど……",
		"voice_file": "VOICE_MAIN_001_036_00371",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 23,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "私たちのことは私たちで決めます！",
		"voice_file": "VOICE_MAIN_001_036_00372",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 24,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "ええ、パルメ族の「管理」なんてお断りよ！",
		"voice_file": "VOICE_MAIN_002_036_00373",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 25,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "ふん、反発するか……",
		"voice_file": "VOICE_MAIN_227_036_00374",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 26,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "素直に従われてもつまらんと思っていたが、",
		"voice_file": "VOICE_MAIN_227_036_00375",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 27,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "面と向かって逆らわれると腹が立つな",
		"voice_file": "",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 28,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "この英雄ヘルトの言を聞き入れないとどうなるか……",
		"voice_file": "VOICE_MAIN_227_036_00376",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 29,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "初見の奴らにも、教えてやらないといけないな……！",
		"voice_file": "VOICE_MAIN_227_036_00377",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 30,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "っ……！！",
		"voice_file": "VOICE_MAIN_001_036_00378",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 31,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "暴れたいだろうゼロ、まずお前が見せつけてやれ",
		"voice_file": "VOICE_MAIN_227_036_00379",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 32,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "さすが兄者、よくぞ我に譲ってくれた",
		"voice_file": "VOICE_MAIN_228_036_00380",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 33,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "久方ぶりの戦じゃ、たぎるのう！！",
		"voice_file": "",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 34,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "い、生きて……る？",
		"voice_file": "VOICE_MAIN_150_036_00381",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 35,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "外れた？　ううん……外してくれた？",
		"voice_file": "VOICE_MAIN_150_036_00382",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 36,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "兄者の分も残しておかねばな！",
		"voice_file": "VOICE_MAIN_228_036_00383",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 37,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "我はよくできた妹じゃ！",
		"voice_file": "",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 38,
		"localized_name": "ジェロン",
		"romanized_name": "Geron",
		"model_path_hash": "9151749121035711876",
		"text": "はあああッ！！！",
		"voice_file": "VOICE_MAIN_003_036_00384",
		"still_path_hash": "8725176872512870759",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 39,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "ふむ。お前、確かジェロンとかいったな",
		"voice_file": "VOICE_MAIN_227_036_00385",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 40,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "パルメ族の「管理」対象と聞いていたが、所詮はこの程度か",
		"voice_file": "VOICE_MAIN_227_036_00386",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 41,
		"localized_name": "ティム",
		"romanized_name": "Tim",
		"model_path_hash": "9091556145679123684",
		"text": "兄さんっ！",
		"voice_file": "VOICE_MAIN_604_036_00387",
		"still_path_hash": "6387934691877097610",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 42,
		"localized_name": "ジェロン",
		"romanized_name": "Geron",
		"model_path_hash": "9151749121035711876",
		"text": "ふっ！",
		"voice_file": "VOICE_MAIN_003_036_00388",
		"still_path_hash": "8725176872512870759",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 43,
		"localized_name": "ジェロン",
		"romanized_name": "Geron",
		"model_path_hash": "9151749121035711876",
		"text": "はっ！",
		"voice_file": "VOICE_MAIN_003_036_00389",
		"still_path_hash": "8725176872512870759",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 44,
		"localized_name": "ジェロン",
		"romanized_name": "Geron",
		"model_path_hash": "9151749121035711876",
		"text": "おおおおッ！！",
		"voice_file": "VOICE_MAIN_003_036_00390",
		"still_path_hash": "8725176872512870759",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 45,
		"localized_name": "ジェロン",
		"romanized_name": "Geron",
		"model_path_hash": "9151749121035711876",
		"text": "っ！",
		"voice_file": "VOICE_MAIN_003_036_00391",
		"still_path_hash": "8725176872512870759",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 46,
		"localized_name": "ティム",
		"romanized_name": "Tim",
		"model_path_hash": "9091556145679123684",
		"text": "っ！",
		"voice_file": "VOICE_MAIN_604_036_00392",
		"still_path_hash": "6387934691877097610",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 47,
		"localized_name": "ジェロン",
		"romanized_name": "Geron",
		"model_path_hash": "9151749121035711876",
		"text": "っ……",
		"voice_file": "VOICE_MAIN_003_036_00393",
		"still_path_hash": "8725176872512870759",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 48,
		"localized_name": "ティム",
		"romanized_name": "Tim",
		"model_path_hash": "9091556145679123684",
		"text": "これを！",
		"voice_file": "VOICE_MAIN_604_036_00394",
		"still_path_hash": "6387934691877097610",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 49,
		"localized_name": "ジェロン",
		"romanized_name": "Geron",
		"model_path_hash": "9151749121035711876",
		"text": "ふー……はっ！",
		"voice_file": "VOICE_MAIN_003_036_00395",
		"still_path_hash": "8725176872512870759",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 50,
		"localized_name": "ジェロン",
		"romanized_name": "Geron",
		"model_path_hash": "9151749121035711876",
		"text": "うおおおおォォォッ！！！",
		"voice_file": "VOICE_MAIN_003_036_00396",
		"still_path_hash": "8725176872512870759",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 51,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "っ！",
		"voice_file": "VOICE_MAIN_227_036_00397",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 52,
		"localized_name": "ジェロン",
		"romanized_name": "Geron",
		"model_path_hash": "9151749121035711876",
		"text": "はああああァァァァァッ！！",
		"voice_file": "VOICE_MAIN_003_036_00398",
		"still_path_hash": "8725176872512870759",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 53,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "ふん……",
		"voice_file": "VOICE_MAIN_227_036_00399",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 54,
		"localized_name": "ジェロン",
		"romanized_name": "Geron",
		"model_path_hash": "9151749121035711876",
		"text": "はあ……はあ……",
		"voice_file": "VOICE_MAIN_003_036_00400",
		"still_path_hash": "8725176872512870759",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 55,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "ほう、そっちのほうが面白そうじゃの",
		"voice_file": "VOICE_MAIN_228_036_00401",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 56,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "こいつは俺が相手をする。お前は残りをやれ",
		"voice_file": "VOICE_MAIN_227_036_00402",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 57,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "兄者は、一番美味しいところは自分で食べるのう",
		"voice_file": "VOICE_MAIN_228_036_00403",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 58,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "立てい。続きじゃ続きじゃ",
		"voice_file": "VOICE_MAIN_228_036_00404",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 59,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "……次はこちらから行くぞ",
		"voice_file": "VOICE_MAIN_227_036_00405",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 60,
		"localized_name": "ジェロン",
		"romanized_name": "Geron",
		"model_path_hash": "9151749121035711876",
		"text": "っ……！",
		"voice_file": "VOICE_MAIN_003_036_00406",
		"still_path_hash": "8725176872512870759",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 61,
		"localized_name": "ジェロン",
		"romanized_name": "Geron",
		"model_path_hash": "9151749121035711876",
		"text": "うっ……！",
		"voice_file": "VOICE_MAIN_003_036_00407",
		"still_path_hash": "8725176872512870759",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 62,
		"localized_name": "ジェロン",
		"romanized_name": "Geron",
		"model_path_hash": "9151749121035711876",
		"text": "ぐお……ッ！！",
		"voice_file": "VOICE_MAIN_003_036_00408",
		"still_path_hash": "8725176872512870759",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 63,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "やるじゃないかジェロン。先ほどの言葉、撤回しよう",
		"voice_file": "VOICE_MAIN_227_036_00409",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 64,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "骨のある奴だ",
		"voice_file": "",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 65,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "その栄誉を称え、この俺の手で「管理」してやる",
		"voice_file": "VOICE_MAIN_227_036_00410",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	}
]