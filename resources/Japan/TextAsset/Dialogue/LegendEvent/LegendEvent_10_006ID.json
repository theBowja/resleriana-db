[
	{
		"id": 0,
		"localized_name": "シャルロッテ",
		"romanized_name": "Shallotte",
		"model_path_hash": "8971561709699782619",
		"text": "わーっ、海ってやっぱり広いね！　\n見渡す限り水ばっかり！",
		"voice_file": "",
		"still_path_hash": "5588667421325366917",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "シャリステラ",
		"romanized_name": "Shallistera",
		"model_path_hash": "8814674670384979784",
		"text": "本当に……\n何度見ても、不思議な気持ちになるね",
		"voice_file": "",
		"still_path_hash": "2239883848991404562",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "ユリエ",
		"romanized_name": "Jurie",
		"model_path_hash": "6932496336129827816",
		"text": "うん。余計なものが何もなくて、風も心地いい",
		"voice_file": "",
		"still_path_hash": "8415011553540267009",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "ミルカ",
		"romanized_name": "Miruca",
		"model_path_hash": "6658023269359396885",
		"text": "……こんなに何もない場所、なんだか落ち着かない",
		"voice_file": "",
		"still_path_hash": "1034358740077913276",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "コルテス",
		"romanized_name": "Kortes",
		"model_path_hash": "6745194160365014115",
		"text": "でも、たまには悪くないだろ",
		"voice_file": "",
		"still_path_hash": "3797902451650633333",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "ユリエ",
		"romanized_name": "Jurie",
		"model_path_hash": "6932496336129827816",
		"text": "ミルカ、体調が悪くなったらすぐに言うのよ",
		"voice_file": "",
		"still_path_hash": "8415011553540267009",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "ミルカ",
		"romanized_name": "Miruca",
		"model_path_hash": "6658023269359396885",
		"text": "もう、大丈夫よ",
		"voice_file": "",
		"still_path_hash": "1034358740077913276",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "コルテス",
		"romanized_name": "Kortes",
		"model_path_hash": "6745194160365014115",
		"text": "ははっ、姉妹仲良しでいいな。\nな、シャリー",
		"voice_file": "",
		"still_path_hash": "3797902451650633333",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "シャリステラ",
		"romanized_name": "Shallistera",
		"model_path_hash": "8814674670384979784",
		"text": "ふふ、そうですね",
		"voice_file": "",
		"still_path_hash": "2239883848991404562",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "ユリエ",
		"romanized_name": "Jurie",
		"model_path_hash": "6932496336129827816",
		"text": "……こうしていられるのも、あとどれくらいかしらね",
		"voice_file": "",
		"still_path_hash": "8415011553540267009",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "ミルカ",
		"romanized_name": "Miruca",
		"model_path_hash": "6658023269359396885",
		"text": "……姉さん？",
		"voice_file": "",
		"still_path_hash": "1034358740077913276",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "ユリエ",
		"romanized_name": "Jurie",
		"model_path_hash": "6932496336129827816",
		"text": "……ううん、なんでもない。\nちょっと、感傷に浸っちゃっただけ",
		"voice_file": "",
		"still_path_hash": "8415011553540267009",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "ミルカ",
		"romanized_name": "Miruca",
		"model_path_hash": "0",
		"text": "…………",
		"voice_file": "",
		"still_path_hash": "1034358740077913276",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "シャルロッテ",
		"romanized_name": "Shallotte",
		"model_path_hash": "8971561709699782619",
		"text": "ねぇねぇ、もうすぐつく？\nヴィアベル州、そろそろ見えるかな？",
		"voice_file": "",
		"still_path_hash": "5588667421325366917",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "シャリステラ",
		"romanized_name": "Shallistera",
		"model_path_hash": "8814674670384979784",
		"text": "まだ見えないけど……風が強くなってきたね。\nヴィアベル州が近いのかも！",
		"voice_file": "",
		"still_path_hash": "2239883848991404562",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 15,
		"localized_name": "ユリエ",
		"romanized_name": "Jurie",
		"model_path_hash": "6932496336129827816",
		"text": "……コルテス、波が高くなってきたわ。\n操縦、大丈夫？",
		"voice_file": "",
		"still_path_hash": "8415011553540267009",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 16,
		"localized_name": "コルテス",
		"romanized_name": "Kortes",
		"model_path_hash": "6745194160365014115",
		"text": "問題ない。だが、お前らはしっかり掴まってろ。\nヴィアベル州の沖は、潮の流れが複雑だからな",
		"voice_file": "",
		"still_path_hash": "3797902451650633333",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 17,
		"localized_name": "ミルカ",
		"romanized_name": "Miruca",
		"model_path_hash": "6658023269359396885",
		"text": "……船が揺れて、ちょっと気持ち悪いかも",
		"voice_file": "",
		"still_path_hash": "1034358740077913276",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 18,
		"localized_name": "ユリエ",
		"romanized_name": "Jurie",
		"model_path_hash": "6932496336129827816",
		"text": "ミルカ、大丈夫？　\n私に寄りかかってくれていいわよ",
		"voice_file": "",
		"still_path_hash": "8415011553540267009",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 19,
		"localized_name": "ミルカ",
		"romanized_name": "Miruca",
		"model_path_hash": "6658023269359396885",
		"text": "……ありがと、姉さん。\n少しだけ、借りるわ",
		"voice_file": "",
		"still_path_hash": "1034358740077913276",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 20,
		"localized_name": "ユリエ",
		"romanized_name": "Jurie",
		"model_path_hash": "6932496336129827816",
		"text": "ええ。存分に頼ってちょうだい",
		"voice_file": "",
		"still_path_hash": "8415011553540267009",
		"speech_balloon_type_id": 780292254
	}
]