[
	{
		"id": 0,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "――みんな大変！\n今、緊急で配信を始めてるんだけど……！",
		"voice_file": "VOICE_MAIN_200_504_01099",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "ベップ",
		"romanized_name": "Bepp",
		"model_path_hash": "3101416597918110218",
		"text": "私たちが出演予定のカウントダウンフェス、\n開催できなくなっちゃうかもしれないって",
		"voice_file": "VOICE_MAIN_151_504_01100",
		"still_path_hash": "5045460652135134961",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "ヤドヴィガ",
		"romanized_name": "Jadwiga",
		"model_path_hash": "2111970354351478659",
		"text": "状況説明。大雪で会場が使用不能になり、\n開催日までの復旧が困難な状況にある模様",
		"voice_file": "VOICE_MAIN_199_504_01101",
		"still_path_hash": "6170794110252514656",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "ベップ",
		"romanized_name": "Bepp",
		"model_path_hash": "3101416597918110218",
		"text": "私たちなら雪の中でもライブできるけど",
		"voice_file": "VOICE_MAIN_151_504_01102",
		"still_path_hash": "5045460652135134961",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "お客さんが来れないよ……",
		"voice_file": "VOICE_MAIN_200_504_01103",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "でも、安心して！　別の会場で開催できるように\n運営さんが動いてくれてるみたい！",
		"voice_file": "VOICE_MAIN_200_504_01104",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "ベップ",
		"romanized_name": "Bepp",
		"model_path_hash": "3101416597918110218",
		"text": "と、いうわけで。\n今日はその新しい会場予定地に来てみたわ",
		"voice_file": "VOICE_MAIN_151_504_01105",
		"still_path_hash": "5045460652135134961",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "ヤドヴィガ",
		"romanized_name": "Jadwiga",
		"model_path_hash": "2111970354351478659",
		"text": "私立ランターナ学園。\n創立２００年を超える由緒ある名門",
		"voice_file": "VOICE_MAIN_199_504_01106",
		"still_path_hash": "6170794110252514656",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "王都のド真ん中にあるおっきい学校だよね",
		"voice_file": "VOICE_MAIN_200_504_01107",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "見て、こーんなに広いグラウンド！\nここがライブ会場になるんだって！",
		"voice_file": "VOICE_MAIN_200_504_01108",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "ヤドヴィガ",
		"romanized_name": "Jadwiga",
		"model_path_hash": "2111970354351478659",
		"text": "……関係者発見",
		"voice_file": "VOICE_MAIN_199_504_01109",
		"still_path_hash": "6170794110252514656",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "あっ！　おーい、みんなー！",
		"voice_file": "VOICE_MAIN_200_504_01110",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "やや、皆様お揃いで",
		"voice_file": "VOICE_MAIN_181_504_01111",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "なに？　もしかして配信中？",
		"voice_file": "VOICE_MAIN_004_504_01112",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "やっほー！　『Ｃｕｔｉｅ☆ＡｎｉｍａＬ』でーす！",
		"voice_file": "VOICE_MAIN_048_504_01113",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 15,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "この間のコラボ動画、みんな楽しんでくれた？\n……うんうん、楽しかったよねー",
		"voice_file": "VOICE_MAIN_200_504_01114",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 16,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "『Ｃｕｔｉｅ☆ＡｎｉｍａＬ』のみんなも、\n私たちと一緒に今度のフェスに出演予定なんだよね",
		"voice_file": "VOICE_MAIN_200_504_01115",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 17,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "ええ。これも、共に盛り上げてくださった\n皆様のおかげでございまする",
		"voice_file": "VOICE_MAIN_181_504_01116",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 18,
		"localized_name": "ベップ",
		"romanized_name": "Bepp",
		"model_path_hash": "3101416597918110218",
		"text": "ところで、どうやらあなたたちが会場設営に\n一枚噛んでるって話らしいけど",
		"voice_file": "VOICE_MAIN_151_504_01117",
		"still_path_hash": "5045460652135134961",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 19,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "私たちというより、うちの社長がね。\nこの場所を使えるように色々動いてくれてるみたい",
		"voice_file": "VOICE_MAIN_004_504_01118",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 20,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "でも、絶対に中止にしたくないっていう気持ちは\n社長もアタシたちも同じだよ！",
		"voice_file": "VOICE_MAIN_048_504_01119",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 21,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "拙者らも、微力ながら\n運営に協力させていただいておりまする",
		"voice_file": "VOICE_MAIN_181_504_01120",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 22,
		"localized_name": "ベップ",
		"romanized_name": "Bepp",
		"model_path_hash": "3101416597918110218",
		"text": "これを見てるみんなもそうでしょ？",
		"voice_file": "VOICE_MAIN_151_504_01121",
		"still_path_hash": "5045460652135134961",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 23,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "さっき運営の人に聞いたんだけど……実は、本番に\n間に合わせるためにはまだ人手が足りないんだって",
		"voice_file": "VOICE_MAIN_200_504_01122",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 24,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "そこで！　会場設営の臨時アルバイトを絶賛募集中！\n気になる人は概要欄をチェックしてね！",
		"voice_file": "VOICE_MAIN_200_504_01123",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 25,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "そこまで仕込み済み！？",
		"voice_file": "VOICE_MAIN_004_504_01124",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 26,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "それじゃ、ばいばーい！",
		"voice_file": "VOICE_MAIN_200_504_01125",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 27,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "おおお……先ほどの告知配信、\nみるみるうちに拡散されておりまする……！",
		"voice_file": "VOICE_MAIN_181_504_01126",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 28,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "これなら応募者も増えそうね",
		"voice_file": "VOICE_MAIN_004_504_01127",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 29,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "ありがとう、三人とも！",
		"voice_file": "VOICE_MAIN_048_504_01128",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 30,
		"localized_name": "ヤドヴィガ",
		"romanized_name": "Jadwiga",
		"model_path_hash": "2111970354351478659",
		"text": "構わない。イベントを成功させたいという意志は\n私たちも同じ",
		"voice_file": "VOICE_MAIN_199_504_01129",
		"still_path_hash": "6170794110252514656",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 31,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "ヤド姉の言う通り。私たちは、私たちのできることを\nやっただけだから",
		"voice_file": "VOICE_MAIN_200_504_01130",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 32,
		"localized_name": "ベップ",
		"romanized_name": "Bepp",
		"model_path_hash": "3101416597918110218",
		"text": "必ず、いいフェスにしましょう",
		"voice_file": "VOICE_MAIN_151_504_01131",
		"still_path_hash": "5045460652135134961",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 33,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "……うむ！",
		"voice_file": "VOICE_MAIN_181_504_01132",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	}
]