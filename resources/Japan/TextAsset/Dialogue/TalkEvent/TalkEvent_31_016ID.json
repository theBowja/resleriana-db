[
	{
		"id": 0,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "もう、ダメ……",
		"voice_file": "VOICE_MAIN_200_037_00502",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "イェルカ",
		"romanized_name": "Jelka",
		"model_path_hash": "7989768780593008340",
		"text": "チッ、足が……\n動きな、この凡骨！！",
		"voice_file": "VOICE_MAIN_153_037_00503",
		"still_path_hash": "8715905000688515801",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "さて、残るはヴァレリア、お前だけだ",
		"voice_file": "VOICE_MAIN_227_037_00504",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "まだやるかのぅ？　参ったと言ってしまえ",
		"voice_file": "VOICE_MAIN_228_037_00505",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "はぁ……はぁっ……ま、……まだまだぁ……\n……はぁ、はぁ、はぁ",
		"voice_file": "VOICE_MAIN_002_037_00506",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "？？？",
		"romanized_name": "???",
		"model_path_hash": "0",
		"text": "間に合った！！",
		"voice_file": "VOICE_MAIN_150_037_00507",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "その声は……",
		"voice_file": "VOICE_MAIN_002_037_00508",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "3986021654722714881",
		"text": "すっご、あの二人相手によくここまで……",
		"voice_file": "VOICE_MAIN_150_037_00509",
		"still_path_hash": "4227931788932007159",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "アルビーナ！！",
		"voice_file": "VOICE_MAIN_002_037_00510",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "3986021654722714881",
		"text": "とりあえず、お疲れさま！\nあとはアタシたちに任せて！",
		"voice_file": "VOICE_MAIN_150_037_00511",
		"still_path_hash": "4227931788932007159",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "フン、怖気付いていた雑魚か。\n雑魚が５人増えたところで戦況は変わらん",
		"voice_file": "VOICE_MAIN_227_037_00512",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "エルス",
		"romanized_name": "Els",
		"model_path_hash": "5033911810886101706",
		"text": "状況把握が疎かだな。\n我々は雑魚ではないし――",
		"voice_file": "VOICE_MAIN_222_037_00513",
		"still_path_hash": "532943395044460292",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "ジョゼ",
		"romanized_name": "José",
		"model_path_hash": "0",
		"text": "増えたのは５人だけじゃないぜ！\n俺たちもさ",
		"voice_file": "VOICE_MAIN_223_037_00514",
		"still_path_hash": "1488533364831425921",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "7061794453237574237",
		"text": "わ……身体、動く……！",
		"voice_file": "VOICE_MAIN_048_037_00515",
		"still_path_hash": "7010833269667927555",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "ハイディ",
		"romanized_name": "Heidi",
		"model_path_hash": "4131218363577277631",
		"text": "お待たせ！　こいつで戻って！",
		"voice_file": "VOICE_MAIN_051_037_00516",
		"still_path_hash": "5092952616707211512",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 15,
		"localized_name": "ララ",
		"romanized_name": "Lara",
		"model_path_hash": "4015600840793749786",
		"text": "感謝しますわ",
		"voice_file": "VOICE_MAIN_005_037_00517",
		"still_path_hash": "803162819272915998",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 16,
		"localized_name": "メーヴェ",
		"romanized_name": "Mowen",
		"model_path_hash": "8282561094361780418",
		"text": "さ、起きなさい、レスナ。\nそろそろ目覚める時間よ",
		"voice_file": "VOICE_MAIN_235_037_00518",
		"still_path_hash": "7917604627487944706",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 17,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "ん……んんっ……",
		"voice_file": "VOICE_MAIN_001_037_00519",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 18,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "え……？\nお、お母さん！？",
		"voice_file": "VOICE_MAIN_001_037_00520",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 19,
		"localized_name": "メーヴェ",
		"romanized_name": "Mowen",
		"model_path_hash": "8282561094361780418",
		"text": "ええ、お母さんよ♪\nでも詳しい話は後！",
		"voice_file": "VOICE_MAIN_235_037_00521",
		"still_path_hash": "7917604627487944706",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 20,
		"localized_name": "メーヴェ",
		"romanized_name": "Mowen",
		"model_path_hash": "8282561094361780418",
		"text": "今はこの人たちをやっつけるのが先！",
		"voice_file": "VOICE_MAIN_235_037_00522",
		"still_path_hash": "7917604627487944706",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 21,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "う、うん。分かった！",
		"voice_file": "VOICE_MAIN_001_037_00523",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 22,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "3986021654722714881",
		"text": "こ、この前はよくもアタシのこと、\n一般人呼ばわりしてくれたわね！",
		"voice_file": "VOICE_MAIN_150_037_00524",
		"still_path_hash": "4227931788932007159",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 23,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "ほう、装いを変えて強がれるようになったのか？\nだが、結局薄皮一枚剥げば弱気の虫が顔を出す",
		"voice_file": "VOICE_MAIN_227_037_00525",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 24,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "3986021654722714881",
		"text": "うるさい！　確かに弱気だったけど、\nアタシはこの服と共に、それを乗り越えるんじゃい！",
		"voice_file": "VOICE_MAIN_150_037_00526",
		"still_path_hash": "4227931788932007159",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 25,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "命の危機を本能が教えてくれたというのに\nそれを無視して、強者に立ち向かうか",
		"voice_file": "VOICE_MAIN_228_037_00527",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 26,
		"localized_name": "イェルカ",
		"romanized_name": "Jelka",
		"model_path_hash": "7989768780593008340",
		"text": "こういう言葉もあるんだよ。\n身を捨ててこそ浮かぶ瀬もあれ、ってね！",
		"voice_file": "VOICE_MAIN_153_037_00528",
		"still_path_hash": "8715905000688515801",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 27,
		"localized_name": "ヤドヴィガ",
		"romanized_name": "Jadwiga",
		"model_path_hash": "2111970354351478659",
		"text": "形勢、逆転……",
		"voice_file": "VOICE_MAIN_199_037_00529",
		"still_path_hash": "6170794110252514656",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 28,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "ふむ、此度の戦乱、これ以上の役者もおらぬか。\nいよいよ宴も仕上げとなろう……",
		"voice_file": "VOICE_MAIN_228_037_00530",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 29,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "兄者、もう血が抑えられぬ……\nこの力、解放させてもらう",
		"voice_file": "VOICE_MAIN_228_037_00531",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 30,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "……いいだろう、好きなだけ暴れるがいい",
		"voice_file": "VOICE_MAIN_227_037_00532",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 31,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "あんだけ偉そうなこと言って、逃げた！？",
		"voice_file": "VOICE_MAIN_002_037_00533",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 32,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "ち、違うよ……あれは、ゼロ姉貴が本気を出すため……\n逃げたんじゃなくて、攻めてくるってこと",
		"voice_file": "VOICE_MAIN_200_037_00534",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 33,
		"localized_name": "ヤドヴィガ",
		"romanized_name": "Jadwiga",
		"model_path_hash": "2111970354351478659",
		"text": "姉上の本気は敵も仲間もすべて巻き込んでいく。\n兄上の存在は姉上にとって足枷だった",
		"voice_file": "VOICE_MAIN_199_037_00535",
		"still_path_hash": "6170794110252514656",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 34,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "正直、我には兄者のいう試しだなんだは、\nそんなに理解できぬ。だが、それでいいと思っておる",
		"voice_file": "VOICE_MAIN_228_037_00536",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 35,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "我は暴れられれば、それでいい！\nすべてを壊し、屠り、灰燼に帰す！！",
		"voice_file": "VOICE_MAIN_228_037_00537",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 36,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "ヴァレリア、我を従えたくば、力を示せ！\nしかし我はゼロ、我を超え得る者なしじゃ！！",
		"voice_file": "VOICE_MAIN_228_037_00538",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 37,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "まったく、２番目の生まれのくせにゼロなんて\nややこしい真似を",
		"voice_file": "VOICE_MAIN_002_037_00539",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 38,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "3986021654722714881",
		"text": "ああ、怖い、逃げ出したい！\nでもね……それでも、戦わなきゃ！",
		"voice_file": "VOICE_MAIN_150_037_00540",
		"still_path_hash": "4227931788932007159",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 39,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "あの人も……怖いのに、それでも頑張ってる。\n私……だって……やらなきゃ！",
		"voice_file": "VOICE_MAIN_200_037_00541",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 40,
		"localized_name": "ヤドヴィガ",
		"romanized_name": "Jadwiga",
		"model_path_hash": "2111970354351478659",
		"text": "……そうか、これが\nヴァレリア姉上の言う、守りたいという気持ち……",
		"voice_file": "VOICE_MAIN_199_037_00542",
		"still_path_hash": "6170794110252514656",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 41,
		"localized_name": "ヤドヴィガ",
		"romanized_name": "Jadwiga",
		"model_path_hash": "2111970354351478659",
		"text": "キューン、大丈夫。私もついてる。\nあなたは、一人じゃない",
		"voice_file": "VOICE_MAIN_199_037_00543",
		"still_path_hash": "6170794110252514656",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 42,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "……うん、ありがとう！",
		"voice_file": "VOICE_MAIN_200_037_00544",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 43,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "戯れは……しまいじゃ！\n全力全開で、いかせてもらう！！",
		"voice_file": "VOICE_MAIN_228_037_00545",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	}
]