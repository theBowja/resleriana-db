[
	{
		"id": 0,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "イザナイザナ！　今回は何をするのでありまするか？",
		"voice_file": "VOICE_MAIN_181_504_00739",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "クールなアイドルに激ニガの水を飲ませてみたー！",
		"voice_file": "VOICE_MAIN_048_504_00740",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "パチパチパチー！",
		"voice_file": "VOICE_MAIN_181_504_00741",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "ということで、こちらは錬金術士の友達に\n作ってもらった特製のにが～い水だよ！",
		"voice_file": "VOICE_MAIN_048_504_00742",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "見たところ無色透明。匂いもありませぬ。\nこれはヨハナも気付けないでありましょう！",
		"voice_file": "VOICE_MAIN_181_504_00743",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "そしてこっちには、今しがた激しいダンスレッスンを\n終えたヨハナがいるよ！",
		"voice_file": "VOICE_MAIN_048_504_00744",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "きっとゴクリといっちゃうことでしょう！\nどんなリアクションをするか楽しみだなあ",
		"voice_file": "VOICE_MAIN_048_504_00745",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "鬼門",
		"romanized_name": "Kimon",
		"model_path_hash": "4093314950907503731",
		"text": "鬼でござるな",
		"voice_file": "VOICE_MAIN_181_504_00746",
		"still_path_hash": "6299303620813546084",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "じゃ、行くよ！",
		"voice_file": "VOICE_MAIN_048_504_00747",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "ヨハナー、お疲れさま！　お水持って来たよ！",
		"voice_file": "VOICE_MAIN_048_504_00748",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "気が利くじゃない。助かるわ",
		"voice_file": "VOICE_MAIN_004_504_00749",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "……ん？　何を撮ってるの？",
		"voice_file": "VOICE_MAIN_004_504_00750",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "レッスンの合間のプライベートタイムを撮ってるんだー",
		"voice_file": "VOICE_MAIN_048_504_00751",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "ふうん……そんなものをみんな見たいの？\nまあ、ご自由に",
		"voice_file": "VOICE_MAIN_004_504_00752",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "ごく……！？",
		"voice_file": "VOICE_MAIN_004_504_00753",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 15,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "がはっ、げほっ……にがっ！！　何よこれ！！",
		"voice_file": "VOICE_MAIN_004_504_00754",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 16,
		"localized_name": "イザナ/鬼門",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "テッテレー！　ドッキリ、大成功！",
		"voice_file": "VOICE_MAIN_048_504_00755",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 17,
		"localized_name": "不要",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "テッテレー！　ドッキリ、大成功！",
		"voice_file": "VOICE_MAIN_181_504_00756",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 18,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "ドッキリ……？　もしかして、わざと苦い水を？",
		"voice_file": "VOICE_MAIN_004_504_00757",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 19,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "面白いリアクションを見せてくれるかなって思って",
		"voice_file": "VOICE_MAIN_048_504_00758",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 20,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "よくもハメたわね……！",
		"voice_file": "VOICE_MAIN_004_504_00759",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 21,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "3787596258689044991",
		"text": "ひゃー、許して～",
		"voice_file": "VOICE_MAIN_048_504_00760",
		"still_path_hash": "4716347634718713212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 22,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "5020305352148956270",
		"text": "こら、待ちなさい！　絶対あんたにも飲ませる！",
		"voice_file": "VOICE_MAIN_004_504_00761",
		"still_path_hash": "9072463264798612382",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 23,
		"localized_name": "ハイディ",
		"romanized_name": "Heidi",
		"model_path_hash": "525253414527026735",
		"text": "なんか、あの子雰囲気変わった？　おかげで、\n前よりユニットにまとまりがあるように感じるよ",
		"voice_file": "VOICE_MAIN_051_504_00762",
		"still_path_hash": "8455600619670167820",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 24,
		"localized_name": "ララ",
		"romanized_name": "Lara",
		"model_path_hash": "4015600840793749786",
		"text": "ええ、わたくしもそう思いますわ。しかし……",
		"voice_file": "VOICE_MAIN_005_504_00763",
		"still_path_hash": "803162819272915998",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 25,
		"localized_name": "ララ",
		"romanized_name": "Lara",
		"model_path_hash": "4015600840793749786",
		"text": "何がきっかけで変わったのでしょう？\n本当、若者の成長はあっという間ですわね",
		"voice_file": "VOICE_MAIN_005_504_00764",
		"still_path_hash": "803162819272915998",
		"speech_balloon_type_id": 780292254
	}
]